<Window x:Class="ShopmiumPdfAutomator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ShopmiumPdfAutomator"
        Title="⬡ Shopmium PDF Automator"
        Height="780" Width="1100"
        MinHeight="680" MinWidth="900"
        Background="#090B0E"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- Style RadioButton onglet (défini ICI, pas dans App.xaml = pas de conflit) -->
        <Style x:Key="TabRadioStyle" TargetType="RadioButton">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" CornerRadius="4"
                                Background="Transparent" Padding="0,10">
                            <TextBlock x:Name="Lbl"
                                       Text="{TemplateBinding Content}"
                                       HorizontalAlignment="Center"
                                       FontFamily="Segoe UI" FontSize="12"
                                       FontWeight="SemiBold" Foreground="#5A6A80"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd"  Property="Background" Value="#1A2230"/>
                                <Setter TargetName="Lbl" Property="Foreground" Value="#00D4FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Lbl" Property="Foreground" Value="#8899AA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bouton Primaire -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"      Value="#00D4FF"/>
            <Setter Property="Foreground"      Value="#090B0E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="20,12"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#20E0FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#00AACC"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bouton Secondaire -->
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background"      Value="#1A2230"/>
            <Setter Property="Foreground"      Value="#E8EDF5"/>
            <Setter Property="BorderBrush"     Value="#1A2A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="16,9"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#00D4FF"/>
                                <Setter Property="Foreground" Value="#00D4FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="#131920"/>
            <Setter Property="Foreground"      Value="#E8EDF5"/>
            <Setter Property="BorderBrush"     Value="#1A2A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,8"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="CaretBrush"      Value="#00D4FF"/>
            <Setter Property="SelectionBrush"  Value="#00D4FF"/>
        </Style>

        <!-- Style ComboBox avec ControlTemplate complet (fond sombre garanti) -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"      Value="#0A1520"/>
            <Setter Property="Foreground"      Value="#E8F0FF"/>
            <Setter Property="BorderBrush"     Value="#1A3050"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="#0A1520"
                                          BorderBrush="#1A3050"
                                          BorderThickness="1"
                                          Foreground="#E8F0FF"
                                          FontFamily="Consolas"
                                          FontSize="11"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen,
                                              Mode=TwoWay,
                                              RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Margin="6,4"
                                                                  HorizontalAlignment="Left"
                                                                  VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="▾"
                                                           Foreground="#446688"
                                                           FontSize="10"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,4,24,4"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder"
                                        Background="#0A1520"
                                        BorderBrush="#1A3050"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="200">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Style ComboBoxItem -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background"  Value="#0A1520"/>
            <Setter Property="Foreground"  Value="#E8F0FF"/>
            <Setter Property="FontFamily"  Value="Consolas"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="Padding"     Value="8,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A3050"/>
                                <Setter Property="Foreground" Value="#00D4FF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#003060"/>
                                <Setter Property="Foreground" Value="#00D4FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style Label -->
        <Style TargetType="Label">
            <Setter Property="Foreground"  Value="#5A6A80"/>
            <Setter Property="FontFamily"  Value="Consolas"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Padding"     Value="0,0,0,4"/>
        </Style>

        <!-- Style ListBox -->
        <Style TargetType="ListBox">
            <Setter Property="Background"      Value="#131920"/>
            <Setter Property="BorderBrush"     Value="#1A2A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"      Value="#E8EDF5"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="2"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding"     Value="10,7"/>
            <Setter Property="Foreground"  Value="#E8EDF5"/>
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="4"
                                Margin="2,1">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A2230"/>
                                <Setter Property="Foreground" Value="#00D4FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0F1820"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid x:Name="RootGrid">

        <!-- Contenu principal -->
        <Grid x:Name="MainContent">
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
            <RowDefinition x:Name="LicenseWarningRow" Height="0"/>
        </Grid.RowDefinitions>



        <!-- ══ HEADER ══ -->
        <Border Grid.Row="0" Background="#0D1117"
                BorderBrush="#1A2A3A" BorderThickness="0,0,0,1">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="⬡" FontSize="20" Foreground="#00D4FF"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock FontFamily="Segoe UI" FontSize="18" FontWeight="Bold"
                               VerticalAlignment="Center">
                        <Run Text="PDF" Foreground="#E8EDF5"/>
                        <Run Text="gen" Foreground="#00D4FF"/>
                        <Run Text=" v4" Foreground="#00D4FF" FontSize="11"/>
                    </TextBlock>
                </StackPanel>
                <Border Grid.Column="2" Background="#131920"
                        BorderBrush="#1A2A3A" BorderThickness="1"
                        CornerRadius="12" Padding="12,5" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Fill="#5A6A80"
                                 Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Carrefour Market • PDF Generator"
                                   FontFamily="Consolas" FontSize="11"
                                   Foreground="#5A6A80" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ══ CONTENU ══ -->
        <Grid Grid.Row="1" Margin="20,16,20,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="440"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── PANNEAU GAUCHE ── -->
            <Border Grid.Column="0" Background="#0D1117"
                    BorderBrush="#1A2A3A" BorderThickness="1" CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Onglets -->
                    <Border Grid.Row="0" Background="#131920"
                            Margin="12,12,12,0" CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <RadioButton x:Name="TabManuel"
                                         Grid.Column="0"
                                         Content="✎  Manuel"
                                         IsChecked="True"
                                         Checked="Tab_Checked"
                                         Tag="Manual"
                                         GroupName="Tabs"
                                         Style="{StaticResource TabRadioStyle}"/>
                            <RadioButton x:Name="TabAuto"
                                         Grid.Column="1"
                                         Content="◈  Auto"
                                         Checked="Tab_Checked"
                                         Tag="Auto"
                                         GroupName="Tabs"
                                         Style="{StaticResource TabRadioStyle}"/>
                            <RadioButton x:Name="TabParams"
                                         Grid.Column="2"
                                         Content="⚙  Params"
                                         Checked="Tab_Checked"
                                         Tag="Params"
                                         GroupName="Tabs"
                                         Style="{StaticResource TabRadioStyle}"/>
                            <RadioButton x:Name="TabShopmiumApi"
                                         Grid.Column="3"
                                         Content="🚀  API"
                                         Checked="Tab_Checked"
                                         Tag="ShopmiumApi"
                                         GroupName="Tabs"
                                         Style="{StaticResource TabRadioStyle}"/>

                        </Grid>
                    </Border>

                    <!-- Contenu onglets -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  Background="Transparent">
                        <Grid Margin="16,12,16,16">

                            <!-- ═══ ONGLET MANUEL ═══ -->
                            <StackPanel x:Name="PanelManuel" Visibility="Visible">

                                <TextBlock Text="INFORMATIONS PRODUIT"
                                           FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                                           Foreground="#5A6A80" Margin="0,0,0,12"/>

                                <Label Content="NOM DU PRODUIT"/>
                                <TextBox x:Name="InputProduct" Margin="0,0,0,4"
                                         Text="TOUCHER MAGIQUE 4D ULTRA CONFORT 6 RLX XL"/>
                                <TextBlock Text="Ligne 1 : 18 car. max  •  Ligne 2 : 22 car. max"
                                           FontFamily="Consolas" FontSize="10"
                                           Foreground="#5A6A80" Margin="0,0,0,14"/>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <Label Content="QUANTITÉ"/>
                                        <TextBox x:Name="InputQty" Text="5"
                                                 TextChanged="Calc_Changed"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <Label Content="PRIX UNITAIRE (€)"/>
                                        <TextBox x:Name="InputPrice" Text="3.99"
                                                 TextChanged="Calc_Changed"/>
                                    </StackPanel>
                                </Grid>

                                <Label Content="TAUX DE TVA"/>
                                <ComboBox x:Name="CbTva" Margin="0,0,0,12"
                                          SelectionChanged="Calc_Changed">
                                    <ComboBoxItem Tag="0.20" IsSelected="True"
                                                  Content="20 % — Alcool / Hygiène / Standard"/>
                                    <ComboBoxItem Tag="0.055"
                                                  Content="5,5 % — Alimentaire / Lait bébé"/>
                                    <ComboBoxItem Tag="0.10"
                                                  Content="10 % — Restauration"/>
                                </ComboBox>

                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#131920"
                                            BorderBrush="#1A2A3A" BorderThickness="1"
                                            CornerRadius="6" Padding="12,10">
                                        <StackPanel>
                                            <TextBlock Text="TOTAL TTC" FontFamily="Consolas"
                                                       FontSize="9" Foreground="#5A6A80"/>
                                            <TextBlock x:Name="LblTotal" Text="19.95 €"
                                                       FontFamily="Consolas" FontSize="16"
                                                       FontWeight="Bold" Foreground="#00D4FF"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Background="#131920"
                                            BorderBrush="#1A2A3A" BorderThickness="1"
                                            CornerRadius="6" Padding="12,10">
                                        <StackPanel>
                                            <TextBlock Text="TVA" FontFamily="Consolas"
                                                       FontSize="9" Foreground="#5A6A80"/>
                                            <TextBlock x:Name="LblTva" Text="1.99 €"
                                                       FontFamily="Consolas" FontSize="16"
                                                       FontWeight="Bold" Foreground="#00D4FF"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <TextBlock Text="DATE &amp; HEURE"
                                           FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                                           Foreground="#5A6A80" Margin="0,0,0,12"/>

                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <Label Content="DATE (JJ/MM/AAAA)"/>
                                        <TextBox x:Name="InputDate" Text="13/02/2026"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <Label Content="HEURE (vide = aléatoire)"/>
                                        <TextBox x:Name="InputTime" Text=""
                                                 ToolTip="Laisser vide pour une heure aléatoire"/>
                                    </StackPanel>
                                </Grid>

                                <Button x:Name="BtnGenerateManual"
                                        Content="⬡   GÉNÉRER LE PNG"
                                        Style="{StaticResource BtnPrimary}"
                                        Height="46" Click="BtnGenerateManual_Click"/>

                            </StackPanel>

                            <!-- ═══ ONGLET AUTO ═══ -->
                            <StackPanel x:Name="PanelAuto" Visibility="Collapsed">

                                <Border Background="#131920" BorderBrush="#00D4FF"
                                        BorderThickness="0,0,0,1" Padding="0,0,0,12"
                                        Margin="0,0,0,16">
                                    <TextBlock TextWrapping="Wrap" FontSize="11"
                                               Foreground="#8899AA" LineHeight="18">
                                        Extrait automatiquement les données de vos favoris Shopmium.
                                        TVA détectée automatiquement. Heure générée aléatoirement.
                                    </TextBlock>
                                </Border>

                                <!-- Étape 1 -->
                                <TextBlock Text="ÉTAPE 1 — PAGE FAVORIS"
                                           FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                                           Foreground="#5A6A80" Margin="0,0,0,8"/>
                                <TextBlock TextWrapping="Wrap" FontSize="11"
                                           Foreground="#8899AA" Margin="0,0,0,6">
                                    Ouvrez la page ci-dessous, puis Ctrl+U&#160;→ Ctrl+A&#160;→ Ctrl+C :
                                </TextBlock>
                                <TextBlock Margin="0,0,0,8">
                                    <Hyperlink NavigateUri="https://app.shopmium.com/fr/favorites"
                                               RequestNavigate="Hyperlink_RequestNavigate"
                                               Foreground="#00AAFF">
                                        <Run Text="🔗  app.shopmium.com/fr/favorites"
                                             FontFamily="Consolas" FontSize="11"
                                             FontWeight="Bold"/>
                                    </Hyperlink>
                                </TextBlock>
                                <TextBox x:Name="InputFavHtml" Height="80"
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         FontSize="10" Margin="0,0,0,8"/>
                                <Button Content="Analyser les favoris →"
                                        Style="{StaticResource BtnSecondary}"
                                        HorizontalAlignment="Left"
                                        Click="BtnParseFavorites_Click"
                                        Margin="0,0,0,16"/>

                                <!-- Étape 2 -->
                                <TextBlock Text="ÉTAPE 2 — SÉLECTIONNER UN PRODUIT"
                                           FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                                           Foreground="#5A6A80" Margin="0,0,0,8"/>
                                <ListBox x:Name="ProductList" Height="110"
                                         SelectionChanged="ProductList_SelectionChanged"
                                         Margin="0,0,0,16"/>

                                <!-- Étape 3 -->
                                <TextBlock Text="ÉTAPE 3 — PAGE PRODUIT"
                                           FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                                           Foreground="#5A6A80" Margin="0,0,0,8"/>
                                <TextBlock x:Name="LblStep3" TextWrapping="Wrap"
                                           FontSize="11" Foreground="#8899AA"
                                           Text="Sélectionnez un produit à l'étape 2"
                                           Margin="0,0,0,8"/>
                                <Button x:Name="BtnOpenProduct"
                                        Content="Ouvrir la page produit →"
                                        Style="{StaticResource BtnSecondary}"
                                        HorizontalAlignment="Left"
                                        Visibility="Collapsed"
                                        Click="BtnOpenProduct_Click"
                                        Margin="0,0,0,8"/>
                                <TextBox x:Name="InputProdHtml" Height="80"
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         FontSize="10" Margin="0,0,0,8"/>
                                <Button Content="Extraire les données →"
                                        Style="{StaticResource BtnSecondary}"
                                        HorizontalAlignment="Left"
                                        Click="BtnParseProduct_Click"
                                        Margin="0,0,0,16"/>

                                <!-- Étape 4 -->
                                <TextBlock Text="ÉTAPE 4 — DONNÉES EXTRAITES"
                                           FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                                           Foreground="#5A6A80" Margin="0,0,0,8"/>
                                <!-- Panel sélection de référence (si pas de prix) -->
                                <Border x:Name="RefChoicePanel" Visibility="Collapsed"
                                        Background="#0D1B2E" BorderBrush="#FF8C00"
                                        BorderThickness="1" CornerRadius="6"
                                        Padding="12" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="⚠ PLUSIEURS RÉFÉRENCES — CHOISISSEZ UN PRODUIT"
                                                   FontFamily="Consolas" FontSize="9"
                                                   FontWeight="Bold" Foreground="#FF8C00"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="Aucun prix détecté. Sélectionnez la référence à mettre sur le ticket :"
                                                   FontFamily="Consolas" FontSize="9"
                                                   Foreground="#88AACC" TextWrapping="Wrap"
                                                   Margin="0,0,0,8"/>
                                        <ItemsControl x:Name="RefChoiceList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Content="{Binding}"
                                                            Tag="{Binding}"
                                                            HorizontalAlignment="Stretch"
                                                            HorizontalContentAlignment="Left"
                                                            Margin="0,0,0,4" Padding="8,5"
                                                            FontFamily="Consolas" FontSize="9"
                                                            Background="#0A1520" Foreground="#00D4FF"
                                                            BorderBrush="#1A4060" BorderThickness="1"
                                                            Cursor="Hand"
                                                            Click="BtnRefChoice_Click"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- Bandeau "référence choisie" + bouton changer -->
                                <Border x:Name="RefChosenBar"
                                        Visibility="Collapsed"
                                        Background="#061A0A" BorderBrush="#1A5020"
                                        BorderThickness="1" CornerRadius="5"
                                        Padding="8,6" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="TbRefChosenName"
                                                   Grid.Column="0"
                                                   FontFamily="Consolas" FontSize="9"
                                                   Foreground="#4CC870"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="Wrap"/>
                                        <Button Grid.Column="1"
                                                Content="✏ Changer"
                                                Click="BtnChangeRef_Click"
                                                Height="24" Padding="8,0"
                                                Margin="8,0,0,0"
                                                FontFamily="Consolas" FontSize="8"
                                                Background="#0A1A10" Foreground="#88BBAA"
                                                BorderBrush="#1A4030" BorderThickness="1"
                                                Cursor="Hand"/>
                                    </Grid>
                                </Border>

                                <Border x:Name="ExtractedPanel" Visibility="Collapsed"
                                        Background="#131920" BorderBrush="#1A2A3A"
                                        BorderThickness="1" CornerRadius="6"
                                        Padding="12" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <!-- Labels -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,0,5"
                                                   Text="Produit" FontFamily="Consolas"
                                                   FontSize="10" Foreground="#5A6A80"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,0,5"
                                                   Text="Articles max" FontFamily="Consolas"
                                                   FontSize="10" Foreground="#5A6A80"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,0,5"
                                                   Text="Prix unitaire" FontFamily="Consolas"
                                                   FontSize="10" Foreground="#5A6A80"/>
                                        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,0,5"
                                                   Text="Total TTC" FontFamily="Consolas"
                                                   FontSize="10" Foreground="#5A6A80"/>
                                        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,0,5"
                                                   Text="TVA" FontFamily="Consolas"
                                                   FontSize="10" Foreground="#5A6A80"/>
                                        <TextBlock Grid.Row="5" Grid.Column="0"
                                                   Text="Date" FontFamily="Consolas"
                                                   FontSize="10" Foreground="#5A6A80"/>
                                        <!-- Valeurs -->
                                        <TextBlock x:Name="ExtProduit" Grid.Row="0" Grid.Column="1"
                                                   Margin="0,0,0,5" FontFamily="Consolas"
                                                   FontSize="10" Foreground="#00D4FF"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock x:Name="ExtArticles" Grid.Row="1" Grid.Column="1"
                                                   Margin="0,0,0,5" FontFamily="Consolas"
                                                   FontSize="10" Foreground="#00D4FF"/>
                                        <TextBlock x:Name="ExtPrix" Grid.Row="2" Grid.Column="1"
                                                   Margin="0,0,0,5" FontFamily="Consolas"
                                                   FontSize="10" Foreground="#00D4FF"/>
                                        <TextBlock x:Name="ExtTotal" Grid.Row="3" Grid.Column="1"
                                                   Margin="0,0,0,5" FontFamily="Consolas"
                                                   FontSize="10" Foreground="#00D4FF"/>
                                        <StackPanel Grid.Row="4" Grid.Column="1"
                                                            Margin="0,0,0,5">
                                            <TextBlock x:Name="ExtTva"
                                                       FontFamily="Consolas" FontSize="10"
                                                       Foreground="#00D4FF"
                                                       Margin="0,0,0,4"/>
                                            <ComboBox x:Name="CbAutoTva"
                                                      FontFamily="Consolas" FontSize="9"
                                                      Background="#0A1520"
                                                      Foreground="#E8F0FF"
                                                      BorderBrush="#1A3050"
                                                      SelectionChanged="CbAutoTva_SelectionChanged">
                                                <ComboBoxItem x:Name="CbAutoTvaAuto"
                                                              Tag="auto"
                                                              Content="Automatique"
                                                              IsSelected="True"/>
                                                <ComboBoxItem Tag="0.055" Content="5,5 %"/>
                                                <ComboBoxItem Tag="0.10"  Content="10,0 %"/>
                                                <ComboBoxItem Tag="0.20"  Content="20,0 %"/>
                                                <ComboBoxItem Tag="0.021" Content="2,1 %"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <TextBlock x:Name="ExtDate" Grid.Row="5" Grid.Column="1"
                                                   FontFamily="Consolas" FontSize="10"
                                                   Foreground="#00D4FF"/>
                                    </Grid>
                                </Border>

                                <!-- ══ TYPE DE TICKET ══ -->
                                <Border x:Name="TicketTypePanel"
                                        Background="#0A1820" BorderBrush="#1A3050"
                                        BorderThickness="1" CornerRadius="6"
                                        Padding="10,8" Margin="0,0,0,10">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="🧾 TYPE DE TICKET"
                                                       FontFamily="Consolas" FontSize="9"
                                                       FontWeight="Bold" Foreground="#446688"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TbTicketTypeAuto"
                                                       FontFamily="Consolas" FontSize="9"
                                                       Foreground="#00D4FF"
                                                       VerticalAlignment="Center"
                                                       Margin="8,0,0,0" Text=""/>
                                        </StackPanel>

                                        <!-- Menu déroulant (toujours visible pour choix manuel) -->
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Forcer :"
                                                       FontFamily="Consolas" FontSize="8"
                                                       Foreground="#556688"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,6,0"/>
                                            <ComboBox x:Name="CbTicketType"
                                                      FontFamily="Consolas" FontSize="9"
                                                      Background="#081018" Foreground="#00D4FF"
                                                      BorderBrush="#1A4060"
                                                      Padding="6,3"
                                                      SelectionChanged="CbTicketType_SelectionChanged">
                                                <ComboBoxItem Tag="Standard"   Content="🧾 Ticket standard"/>
                                                <ComboBoxItem Tag="Leclerc"    Content="🟠 Ticket Leclerc"/>
                                                <ComboBoxItem Tag="CarrefourDrive" Content="🔵 Ticket Carrefour Drive"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <!-- Avertissement si mismatch -->
                                        <Border x:Name="TicketMismatchPanel"
                                                Visibility="Collapsed"
                                                Background="#1A0800" BorderBrush="#6B3000"
                                                BorderThickness="1" CornerRadius="4"
                                                Padding="6,5" Margin="0,6,0,0">
                                            <TextBlock x:Name="TbTicketMismatch"
                                                       FontFamily="Consolas" FontSize="8"
                                                       Foreground="#FF8C00"
                                                       TextWrapping="Wrap"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- ══ EAN-13 (toujours affiché) ══ -->
                                <Border x:Name="EanPanel"
                                        Visibility="Collapsed"
                                        Background="#0A1520" BorderBrush="#1A3050"
                                        BorderThickness="1" CornerRadius="6"
                                        Padding="10,10" Margin="0,0,0,10">
                                    <StackPanel>
                                        <!-- En-tête EAN-13 -->
                                        <TextBlock Text="EAN-13"
                                                   FontFamily="Consolas" FontSize="9"
                                                   FontWeight="Bold" Foreground="#446688"
                                                   Margin="0,0,0,6"/>

                                        <!-- Champ EAN + boutons inline -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Champ EAN éditable -->
                                            <TextBox x:Name="TbEanCode"
                                                     Grid.Column="0"
                                                     FontFamily="Consolas" FontSize="13"
                                                     FontWeight="Bold"
                                                     Foreground="#00D4FF"
                                                     Background="#081018"
                                                     BorderBrush="#1A4060"
                                                     BorderThickness="1"
                                                     Padding="6,4"
                                                     MaxLength="13"
                                                     Text=""
                                                     ToolTip="Entrez le code EAN-13 du produit"
                                                     TextChanged="TbEanCode_TextChanged"/>

                                            <!-- Copier EAN -->
                                            <Button Grid.Column="1"
                                                    Content="📋 Copier"
                                                    Margin="4,0,0,0" Padding="8,4"
                                                    FontFamily="Consolas" FontSize="9"
                                                    Background="#0A1A30" Foreground="#88AACC"
                                                    BorderBrush="#1A3050" BorderThickness="1"
                                                    Cursor="Hand"
                                                    Click="BtnCopyEan_Click"/>

                                            <!-- Générer code-barres via codebarre.fr -->
                                            <Button Grid.Column="2"
                                                    Content="📊 Code-barres"
                                                    Margin="4,0,0,0" Padding="8,4"
                                                    FontFamily="Consolas" FontSize="9"
                                                    Background="#0A2040" Foreground="#00AACC"
                                                    BorderBrush="#1A4060" BorderThickness="1"
                                                    Cursor="Hand"
                                                    ToolTip="Générer le code-barres via codebarre.fr"
                                                    Click="BtnGenerateBarcode_Click"/>
                                        </Grid>

                                        <TextBlock x:Name="TbEanHint"
                                                   FontFamily="Consolas" FontSize="8"
                                                   Foreground="#334455" Margin="0,5,0,0"
                                                   TextWrapping="Wrap"
                                                   Text="Entrez l'EAN manuellement ou utilisez les boutons ci-dessous"/>

                                        <!-- Boutons de recherche -->
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <Button x:Name="BtnSearchManual"
                                                    Content="🔍 Rechercher sur Auchan"
                                                    Padding="8,5"
                                                    FontFamily="Consolas" FontSize="9"
                                                    Background="#0A1820" Foreground="#88AACC"
                                                    BorderBrush="#1A3050" BorderThickness="1"
                                                    Cursor="Hand" Margin="0,0,6,0"
                                                    Click="BtnSearchManual_Click"/>
                                            <Button x:Name="BtnSearchLeclerc"
                                                    Content="🔍 Rechercher sur Leclerc"
                                                    Padding="8,5"
                                                    FontFamily="Consolas" FontSize="9"
                                                    Background="#0A1820" Foreground="#88AACC"
                                                    BorderBrush="#1A3050" BorderThickness="1"
                                                    Cursor="Hand"
                                                    Click="BtnSearchLeclerc_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- ══ EXIGENCES SUPPLÉMENTAIRES ══ -->
                                <Border x:Name="ProofPanel" Visibility="Collapsed"
                                        Background="#0D1B2E" BorderBrush="#1A4060"
                                        BorderThickness="1" CornerRadius="8"
                                        Padding="14,12" Margin="0,0,0,10">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock Text="📋" FontSize="13"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"/>
                                            <TextBlock Text="EXIGENCES SUPPLÉMENTAIRES"
                                                       FontFamily="Consolas" FontSize="10"
                                                       FontWeight="Bold" Foreground="#00D4FF"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock x:Name="TbProofCount"
                                                   FontFamily="Consolas" FontSize="9"
                                                   Foreground="#446688" Margin="0,0,0,8"/>
                                        <!-- Cartes exigences (générées en C#) -->
                                        <ItemsControl x:Name="ProofRequirementCards">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,10"
                                                            Background="#081018"
                                                            BorderBrush="#1A3050"
                                                            BorderThickness="1"
                                                            CornerRadius="6"
                                                            Padding="10,10">
                                                        <StackPanel>
                                                            <!-- Titre exigence -->
                                                            <TextBlock Text="{Binding Title}"
                                                                       FontFamily="Consolas"
                                                                       FontSize="10"
                                                                       FontWeight="Bold"
                                                                       Foreground="#E8F0FF"
                                                                       TextWrapping="Wrap"
                                                                       Margin="0,0,0,8"/>
                                                            <!-- Bouton Gemini (si disponible) -->
                                                            <Button Tag="{Binding GeminiUrl}"
                                                                    Content="{Binding BtnLabel}"
                                                                    Visibility="{Binding BtnVisibility}"
                                                                    Height="34" Margin="0,0,0,8"
                                                                    Padding="10,0"
                                                                    FontFamily="Consolas"
                                                                    FontSize="10"
                                                                    FontWeight="Bold"
                                                                    Background="#002850"
                                                                    Foreground="#4488FF"
                                                                    BorderBrush="#1A4080"
                                                                    BorderThickness="1"
                                                                    Cursor="Hand"
                                                                    Click="BtnOpenGemini_Click"/>
                                                            <!-- Prompt copiable -->
                                                            <TextBlock Text="Prompt à copier :"
                                                                       Visibility="{Binding PromptVisibility}"
                                                                       FontFamily="Consolas"
                                                                       FontSize="8"
                                                                       Foreground="#446688"
                                                                       Margin="0,0,0,4"/>
                                                            <Border Visibility="{Binding PromptVisibility}"
                                                                    Background="#040810"
                                                                    BorderBrush="#1A2A3A"
                                                                    BorderThickness="1"
                                                                    CornerRadius="4"
                                                                    Padding="8,6">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0"
                                                                               Text="{Binding Prompt}"
                                                                               FontFamily="Consolas"
                                                                               FontSize="9"
                                                                               Foreground="#88AACC"
                                                                               TextWrapping="Wrap"/>
                                                                    <Button Grid.Column="1"
                                                                            Tag="{Binding Prompt}"
                                                                            Content="📋"
                                                                            Width="28" Height="28"
                                                                            Margin="6,0,0,0"
                                                                            VerticalAlignment="Top"
                                                                            FontSize="13"
                                                                            Background="#0A1A30"
                                                                            Foreground="#88AACC"
                                                                            BorderBrush="#1A3050"
                                                                            BorderThickness="1"
                                                                            Cursor="Hand"
                                                                            ToolTip="Copier le prompt"
                                                                            Click="BtnCopyPrompt_Click"/>
                                                                </Grid>
                                                            </Border>
                                                            <!-- IMAGE SÉLECTIONNÉE AUTOMATIQUEMENT -->
                                                            <Border Visibility="{Binding BestImageVisibility}"
                                                                    Margin="0,10,0,0"
                                                                    Background="#060E18"
                                                                    BorderBrush="#1A3A60"
                                                                    BorderThickness="1"
                                                                    CornerRadius="6"
                                                                    Padding="10,8">
                                                                <StackPanel>
                                                                    <StackPanel Orientation="Horizontal"
                                                                                Margin="0,0,0,4">
                                                                        <TextBlock Text="🖼  IMAGE SÉLECTIONNÉE"
                                                                                   FontFamily="Consolas"
                                                                                   FontSize="8"
                                                                                   FontWeight="Bold"
                                                                                   Foreground="#446688"
                                                                                   VerticalAlignment="Center"/>
                                                                    </StackPanel>
                                                                    <!-- Conseil : préférer image Auchan/Leclerc -->
                                                                    <Border Background="#0A1A10"
                                                                            BorderBrush="#1A4020"
                                                                            BorderThickness="1"
                                                                            CornerRadius="4"
                                                                            Padding="6,5"
                                                                            Margin="0,0,0,8">
                                                                        <TextBlock FontFamily="Consolas"
                                                                                   FontSize="10"
                                                                                   Foreground="#5AB878"
                                                                                   TextWrapping="Wrap">
                                                                            <Run Text="💡 Conseil : " FontWeight="Bold"/>
                                                                            <Run Text="Préférez l'image du produit disponible sur la page Auchan ou Leclerc plutôt que celle proposée par l'application."
                                                                                 Foreground="#3A8855"/>
                                                                        </TextBlock>
                                                                    </Border>
                                                                    <!-- Aperçu image + bouton -->
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <!-- Miniature -->
                                                                        <Border Grid.Column="0"
                                                                                Width="80" Height="80"
                                                                                Background="#0A1520"
                                                                                BorderBrush="#1A3050"
                                                                                BorderThickness="1"
                                                                                CornerRadius="4"
                                                                                Margin="0,0,10,0">
                                                                            <Image Tag="{Binding BestImageUrl}"
                                                                                   Stretch="Uniform"
                                                                                   Loaded="BestProductImage_Loaded"/>
                                                                        </Border>
                                                                        <!-- Info + boutons -->
                                                                        <StackPanel Grid.Column="1"
                                                                                    VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding BestImageNote}"
                                                                                       FontFamily="Consolas"
                                                                                       FontSize="8"
                                                                                       Foreground="#5A7A9A"
                                                                                       TextWrapping="Wrap"
                                                                                       Margin="0,0,0,6"/>
                                                                            <!-- Avertissement si mismatch -->
                                                                            <TextBlock Visibility="{Binding WarnVisibility}"
                                                                                       Text="{Binding BestImageWarning}"
                                                                                       FontFamily="Consolas"
                                                                                       FontSize="8"
                                                                                       Foreground="#FFAA44"
                                                                                       TextWrapping="Wrap"
                                                                                       Margin="0,0,0,6"/>
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <Button Tag="{Binding BestImageData}"
                                                                                        Content="📥 Copier image"
                                                                                        Height="26" Padding="8,0"
                                                                                        FontFamily="Consolas"
                                                                                        FontSize="9"
                                                                                        Background="#002030"
                                                                                        Foreground="#28C840"
                                                                                        BorderBrush="#1A4030"
                                                                                        BorderThickness="1"
                                                                                        Cursor="Hand"
                                                                                        ToolTip="Copier l'image dans le presse-papier"
                                                                                        Click="BtnCopyImageData_Click"/>
                                                                            </StackPanel>
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </StackPanel>
                                                            </Border>

                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                                                <!-- ══ Avertissement EAN Drive ══ -->
                                                                <Border x:Name="EanDriveWarning"
                                                                        Visibility="Collapsed"
                                                                        Background="#1A0800"
                                                                        BorderBrush="#8B4500"
                                                                        BorderThickness="1" CornerRadius="4"
                                                                        Padding="8,6" Margin="0,0,0,8">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="⚠"
                                                                                   FontSize="11"
                                                                                   Foreground="#FF8C00"
                                                                                   Margin="0,0,6,0"
                                                                                   VerticalAlignment="Center"/>
                                                                        <TextBlock Text="Ticket Carrefour Drive : renseignez le code EAN-13 ci-dessus avant de générer."
                                                                                   FontFamily="Consolas"
                                                                                   FontSize="8"
                                                                                   Foreground="#FF8C00"
                                                                                   TextWrapping="Wrap"/>
                                                                    </StackPanel>
                                                                </Border>

                                                                <!-- Bannière TVA incertaine -->
                                                                <Border x:Name="TvaWarningPanel"
                                                                        Visibility="Collapsed"
                                                                        Background="#0D1A00"
                                                                        BorderBrush="#5A8A00"
                                                                        BorderThickness="1" CornerRadius="4"
                                                                        Padding="8,6" Margin="0,0,0,8">
                                                                    <StackPanel>
                                                                        <TextBlock x:Name="TvaWarningLabel"
                                                                                   Text="⚠ TVA estimée à 5,5% — produit non reconnu. Vérifiez ci-dessous."
                                                                                   FontFamily="Consolas" FontSize="8"
                                                                                   Foreground="#A8D400"
                                                                                   TextWrapping="Wrap"
                                                                                   Margin="0,0,0,4"/>
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <TextBlock Text="Taux TVA :"
                                                                                       FontFamily="Consolas" FontSize="8"
                                                                                       Foreground="#A8D400"
                                                                                       VerticalAlignment="Center"
                                                                                       Margin="0,0,6,0"/>
                                                                            <ComboBox x:Name="CbTvaWarning"
                                                                                      FontFamily="Consolas" FontSize="9"
                                                                                      Height="22" Width="100"
                                                                                      SelectionChanged="CbTvaWarning_SelectionChanged">
                                                                                <ComboBoxItem Tag="0.055" IsSelected="True">5,5% — Alimentaire</ComboBoxItem>
                                                                                <ComboBoxItem Tag="0.10">10% — Restauration</ComboBoxItem>
                                                                                <ComboBoxItem Tag="0.20">20% — Hygiène/Non-alim</ComboBoxItem>
                                                                                <ComboBoxItem Tag="0.021">2,1% — Médicament</ComboBoxItem>
                                                                            </ComboBox>
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                </Border>

                                                                <Button x:Name="BtnGenerateAuto"
                                        Content="⬡   GÉNÉRER LE PNG"
                                        Style="{StaticResource BtnPrimary}"
                                        Height="46" IsEnabled="False"
                                        Click="BtnGenerateAuto_Click"/>
                            </StackPanel>

                            <!-- ═══ ONGLET PARAMS ═══ -->
                            <StackPanel x:Name="PanelParams" Visibility="Collapsed">

                                <TextBlock Text="CONFIGURATION"
                                           FontFamily="Consolas" FontSize="10"
                                           FontWeight="Bold" Foreground="#00D4FF"
                                           Margin="0,0,0,16"/>

                                <!-- Clé API OpenAI -->
                                <Border Background="#0D1B2E" BorderBrush="#1A3050"
                                        BorderThickness="1" CornerRadius="8"
                                        Padding="14,12" Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="📸  GÉNÉRATION D'IMAGE IA (DALL-E 3)"
                                                   FontFamily="Consolas" FontSize="10"
                                                   FontWeight="Bold" Foreground="#00D4FF"
                                                   Margin="0,0,0,10"/>
                                        <TextBlock Text="CLÉ API OPENAI"
                                                   FontFamily="Consolas" FontSize="9"
                                                   Foreground="#446688" Margin="0,0,0,4"/>
                                        <PasswordBox x:Name="PbOpenAiKey"
                                                     FontFamily="Consolas" FontSize="11"
                                                     Background="#0A1520" Foreground="#E8F0FF"
                                                     BorderBrush="#1A3050"
                                                     Padding="8,6" Margin="0,0,0,4"
                                                     ToolTip="Commence par sk- — platform.openai.com/api-keys"/>
                                        <TextBlock Margin="0,2,0,10">
                                            <Hyperlink NavigateUri="https://platform.openai.com/api-keys"
                                                       RequestNavigate="Hyperlink_RequestNavigate"
                                                       Foreground="#0099CC">
                                                <Run Text="🔗  platform.openai.com/api-keys"
                                                     FontFamily="Consolas" FontSize="9"/>
                                            </Hyperlink>
                                        </TextBlock>
                                        <Button x:Name="BtnSaveImageApi"
                                                Content="SAUVEGARDER LA CLÉ"
                                                Height="34"
                                                Click="BtnSaveImageApi_Click">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="#003060"/>
                                                    <Setter Property="Foreground" Value="#00D4FF"/>
                                                    <Setter Property="BorderBrush" Value="#006090"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Setter Property="FontFamily" Value="Consolas"/>
                                                    <Setter Property="FontSize" Value="10"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Cursor" Value="Hand"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}"
                                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                                        CornerRadius="6">
                                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <TextBlock x:Name="TbApiSaveStatus"
                                                   FontFamily="Consolas" FontSize="9"
                                                   Foreground="#28C840"
                                                   Margin="0,6,0,0" Text=""/>
                                    </StackPanel>
                                </Border>

                                <!-- Info version -->
                                <Border Background="#0A1015" BorderBrush="#1A2530"
                                        BorderThickness="1" CornerRadius="8"
                                        Padding="14,12">
                                    <StackPanel>
                                        <TextBlock Text="ℹ  À PROPOS"
                                                   FontFamily="Consolas" FontSize="10"
                                                   FontWeight="Bold" Foreground="#446688"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="Shopmium PDF Automator v18"
                                                   FontFamily="Consolas" FontSize="10"
                                                   Foreground="#334455" Margin="0,0,0,3"/>
                                        <TextBlock Text="Moteur : Adobe Photoshop CC"
                                                   FontFamily="Consolas" FontSize="10"
                                                   Foreground="#334455" Margin="0,0,0,3"/>
                                        <TextBlock Text="TVA : Open Food Facts + USDA + mots-cles"
                                                   FontFamily="Consolas" FontSize="10"
                                                   Foreground="#334455" Margin="0,0,0,3"/>
                                        <TextBlock Text="Image IA : DALL-E 3 (OpenAI)"
                                                   FontFamily="Consolas" FontSize="10"
                                                   Foreground="#334455"/>
                                    </StackPanel>
                                </Border>

                            </StackPanel>


                            <!-- ═══ ONGLET CHAT IA ═══ -->
                            <Grid x:Name="PanelChat" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- ── BLOC CONTEXTE PRODUIT ── -->
                                <Border x:Name="ChatContextPanel"
                                        Grid.Row="0"
                                        Background="#0A1A2A"
                                        BorderBrush="#1A3050"
                                        BorderThickness="1" CornerRadius="8"
                                        Padding="12,10" Margin="0,0,0,10"
                                        Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Text="📋  CONTEXTE PRODUIT CHARGÉ"
                                                   FontFamily="Consolas" FontSize="9"
                                                   FontWeight="Bold" Foreground="#00D4FF"
                                                   Margin="0,0,0,8"/>

                                        <!-- Exigences Shopmium -->
                                        <Border x:Name="ChatRequirementsPanel"
                                                Background="#061018"
                                                BorderBrush="#1A2A3A"
                                                BorderThickness="1" CornerRadius="6"
                                                Padding="10,8" Margin="0,0,0,8"
                                                Visibility="Collapsed">
                                            <StackPanel>
                                                <TextBlock Text="EXIGENCES DÉTECTÉES"
                                                           FontFamily="Consolas" FontSize="8"
                                                           Foreground="#446688"
                                                           FontWeight="Bold"
                                                           Margin="0,0,0,6"/>
                                                <ItemsControl x:Name="ChatRequirementsList">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}"
                                                                       FontFamily="Consolas"
                                                                       FontSize="10"
                                                                       Foreground="#88BBDD"
                                                                       TextWrapping="Wrap"
                                                                       Margin="0,2,0,2"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>

                                        <!-- Infos produit + TVA -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Résumé produit -->
                                            <StackPanel Grid.Column="0">
                                                <TextBlock x:Name="TbChatProductName"
                                                           FontFamily="Consolas" FontSize="10"
                                                           FontWeight="Bold"
                                                           Foreground="#E8F0FF"
                                                           TextWrapping="Wrap"
                                                           Text=""/>
                                                <TextBlock x:Name="TbChatProductDetails"
                                                           FontFamily="Consolas" FontSize="9"
                                                           Foreground="#556677"
                                                           TextWrapping="Wrap"
                                                           Margin="0,2,0,0"
                                                           Text=""/>
                                            </StackPanel>

                                            <!-- Menu TVA -->
                                            <StackPanel Grid.Column="1"
                                                        Margin="10,0,0,0"
                                                        VerticalAlignment="Top">
                                                <TextBlock Text="TVA"
                                                           FontFamily="Consolas" FontSize="8"
                                                           Foreground="#446688"
                                                           Margin="0,0,0,4"/>
                                                <ComboBox x:Name="CbChatTva"
                                                          Width="90"
                                                          FontFamily="Consolas"
                                                          FontSize="10"
                                                          Background="#0A1520"
                                                          Foreground="#E8F0FF"
                                                          BorderBrush="#1A3050"
                                                          SelectionChanged="CbChatTva_SelectionChanged">
                                                    <ComboBoxItem Tag="0.20" Content="20,0 %"/>
                                                    <ComboBoxItem Tag="0.10" Content="10,0 %"/>
                                                    <ComboBoxItem Tag="0.055" Content="5,5 %"/>
                                                    <ComboBoxItem Tag="0.021" Content="2,1 %"/>
                                                </ComboBox>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Image produit -->
                                        <Border Margin="0,8,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <!-- Aperçu image si chargée -->
                                                <Border x:Name="ChatImagePreview"
                                                        Width="60" Height="60"
                                                        Background="#061018"
                                                        BorderBrush="#1A3050"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Margin="0,0,10,0"
                                                        Visibility="Collapsed">
                                                    <Image x:Name="ChatProductThumb"
                                                           Stretch="Uniform"/>
                                                </Border>

                                                <StackPanel VerticalAlignment="Center">
                                                    <Button x:Name="BtnChatImportImage"
                                                            Content="📎  Importer image produit"
                                                            Height="30" Padding="10,0"
                                                            Click="BtnChatImportImage_Click"
                                                            FontFamily="Consolas" FontSize="9"
                                                            Background="#0A2040"
                                                            Foreground="#00D4FF"
                                                            BorderBrush="#1A4060"
                                                            BorderThickness="1"
                                                            Cursor="Hand"
                                                            Margin="0,0,0,4"/>
                                                    <TextBlock x:Name="TbChatImageStatus"
                                                               FontFamily="Consolas" FontSize="8"
                                                               Foreground="#446688"
                                                               Text="Pas d'image — GPT utilisera le nom du produit"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- ── EN-TÊTE CHAT ── -->
                                <StackPanel Grid.Row="1" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="CHAT GPT-4o"
                                                   FontFamily="Consolas" FontSize="10"
                                                   FontWeight="Bold" Foreground="#5A6A80"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TbChatModel"
                                                   FontFamily="Consolas" FontSize="9"
                                                   Foreground="#334455"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0"
                                                   Text="— gpt-4o"/>
                                        <Button x:Name="BtnClearChat"
                                                Content="🗑  Nouvelle conversation"
                                                Height="22" Margin="12,0,0,0"
                                                Padding="8,0"
                                                Click="BtnClearChat_Click"
                                                FontFamily="Consolas" FontSize="9"
                                                Background="#1A1A2A"
                                                Foreground="#556688"
                                                BorderBrush="#2A3A4A"
                                                Cursor="Hand"/>
                                        <Button x:Name="BtnInjectContext"
                                                Content="⤵  Injecter contexte produit"
                                                Height="22" Margin="8,0,0,0"
                                                Padding="8,0"
                                                Click="BtnInjectContext_Click"
                                                FontFamily="Consolas" FontSize="9"
                                                Background="#002040"
                                                Foreground="#00AACC"
                                                BorderBrush="#1A3050"
                                                Cursor="Hand"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- ── ZONE CHAT ── -->
                                <Grid Grid.Row="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Historique messages -->
                                    <Border Grid.Row="0"
                                            Background="#080E18"
                                            BorderBrush="#1A2A3A"
                                            BorderThickness="1" CornerRadius="8"
                                            Margin="0,0,0,8"
                                            MinHeight="300">
                                        <ScrollViewer x:Name="ChatScrollViewer"
                                                      VerticalScrollBarVisibility="Auto"
                                                      Padding="10,8">
                                            <ItemsControl x:Name="ChatMessages">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,0,8"
                                                                Padding="10,8"
                                                                CornerRadius="6"
                                                                Background="{Binding Background}">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Sender}"
                                                                           FontFamily="Consolas"
                                                                           FontSize="8"
                                                                           FontWeight="Bold"
                                                                           Foreground="{Binding SenderColor}"
                                                                           Margin="0,0,0,4"/>
                                                                <TextBlock Text="{Binding Content}"
                                                                           FontFamily="Consolas"
                                                                           FontSize="11"
                                                                           Foreground="#D0E0FF"
                                                                           TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>

                                    <!-- Zone de saisie -->
                                    <Grid Grid.Row="1" Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="TbChatInput"
                                                 Grid.Column="0"
                                                 Height="70"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 FontFamily="Consolas" FontSize="11"
                                                 Background="#0A1520"
                                                 Foreground="#E8F0FF"
                                                 BorderBrush="#1A3050"
                                                 Padding="8,6"
                                                 ToolTip="Ctrl+Entrée = envoyer"
                                                 KeyDown="TbChatInput_KeyDown"
                                                 Margin="0,0,8,0"/>
                                        <Button x:Name="BtnSendChat"
                                                Grid.Column="1"
                                                Width="70" Height="70"
                                                Click="BtnSendChat_Click"
                                                Cursor="Hand"
                                                Background="#003060"
                                                BorderBrush="#006090"
                                                BorderThickness="1">
                                            <TextBlock Text="➤"
                                                       FontSize="22"
                                                       Foreground="#00D4FF"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Button>
                                    </Grid>

                                    <!-- Hints -->
                                    <TextBlock Grid.Row="2"
                                               Text="Ctrl+Entrée pour envoyer  •  Si image importée, elle est envoyée avec votre prochain message"
                                               FontFamily="Consolas" FontSize="8"
                                               Foreground="#334455"
                                               HorizontalAlignment="Center"/>
                                </Grid>
                            </Grid>


                        </Grid>

                            <!-- ══════════════════════════════════════════════
                                 PANNEAU API SHOPMIUM
                            ═══════════════════════════════════════════════ -->
                            <StackPanel x:Name="PanelShopmiumApi" Visibility="Collapsed">

                                <!-- Connexion -->
                                <TextBlock Text="🔐 Connexion Shopmium"
                                           Foreground="#A0B8D0" FontSize="11"
                                           FontWeight="SemiBold" Margin="0,0,0,6"/>

                                <Border Background="#0A1520" BorderBrush="#1A3050"
                                        BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Email" Foreground="#607080"
                                                   FontSize="10" Margin="0,0,0,4"/>
                                        <TextBox x:Name="ApiEmail" Margin="0,0,0,8"
                                                 Height="32" FontSize="12"/>

                                        <TextBlock Text="Mot de passe" Foreground="#607080"
                                                   FontSize="10" Margin="0,0,0,4"/>
                                        <PasswordBox x:Name="ApiPassword" Margin="0,0,0,10"
                                                     Height="32" FontSize="12"
                                                     Background="#131920" Foreground="White"
                                                     BorderBrush="#1A3050"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="ApiLoginStatus"
                                                       Grid.Column="0"
                                                       Text="Non connecté"
                                                       Foreground="#607080" FontSize="11"
                                                       VerticalAlignment="Center"/>
                                            <Button x:Name="BtnApiLogin"
                                                    Grid.Column="1"
                                                    Content="Se connecter"
                                                    Style="{StaticResource BtnPrimary}"
                                                    Padding="14,6"
                                                    Click="BtnApiLogin_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Offres -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="📦 Offres disponibles"
                                               Foreground="#A0B8D0" FontSize="11"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <Button x:Name="BtnApiLoadOffers"
                                            Grid.Column="1"
                                            Content="↻ Charger"
                                            Style="{StaticResource BtnSecondary}"
                                            Padding="10,4" IsEnabled="False"
                                            Click="BtnApiLoadOffers_Click"/>
                                </Grid>

                                <ListBox x:Name="ApiOfferList"
                                         Height="130"
                                         Background="#0A1520"
                                         BorderBrush="#1A3050"
                                         Foreground="#C0D8F0"
                                         FontSize="11"
                                         Margin="0,0,0,8"
                                         SelectionChanged="ApiOfferList_SelectionChanged"/>

                                <!-- Détails offre sélectionnée -->
                                <Border x:Name="ApiOfferDetail" Visibility="Collapsed"
                                        Background="#0A1520" BorderBrush="#1A4060"
                                        BorderThickness="1" CornerRadius="6"
                                        Padding="10" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock x:Name="ApiOfferName"
                                                   Foreground="#00AAFF" FontSize="12"
                                                   FontWeight="SemiBold" TextWrapping="Wrap"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock x:Name="ApiOfferBarcode"
                                                   Foreground="#80A0C0" FontSize="11"
                                                   Margin="0,0,0,2"/>
                                        <TextBlock x:Name="ApiOfferRetailers"
                                                   Foreground="#80A0C0" FontSize="11"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <!-- Soumission -->
                                <TextBlock Text="🚀 Soumettre à Shopmium"
                                           Foreground="#A0B8D0" FontSize="11"
                                           FontWeight="SemiBold" Margin="0,0,0,6"/>

                                <Border Background="#0A1520" BorderBrush="#1A3050"
                                        BorderThickness="1" CornerRadius="6"
                                        Padding="12" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="Image à soumettre" Foreground="#607080"
                                                   FontSize="10" Margin="0,0,0,4"/>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="ApiImagePath"
                                                       Text="Aucune image sélectionnée"
                                                       Foreground="#607080" FontSize="10"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Button Grid.Column="1" Content="Parcourir…"
                                                    Style="{StaticResource BtnSecondary}"
                                                    Padding="8,4"
                                                    Click="BtnApiPickImage_Click"/>
                                        </Grid>

                                        <TextBlock Text="Enseigne (optionnel)"
                                                   Foreground="#607080" FontSize="10"
                                                   Margin="0,0,0,4"/>
                                        <TextBox x:Name="ApiChain"
                                                 Height="30" FontSize="12"
                                                 Margin="0,0,0,10"
                                                 ToolTip="Ex: CARREFOUR, LECLERC, INTERMARCHE…"/>

                                        <Button x:Name="BtnApiSubmit"
                                                Content="🚀  Soumettre le ticket"
                                                Style="{StaticResource BtnPrimary}"
                                                Height="40" IsEnabled="False"
                                                Click="BtnApiSubmit_Click"/>

                                        <TextBlock x:Name="ApiSubmitStatus"
                                                   Text="" Foreground="#00E5A0"
                                                   FontSize="11" TextWrapping="Wrap"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>

                            </StackPanel>

                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ── PANNEAU DROIT : Aperçu ── -->
            <Border Grid.Column="2" Background="#0D1117"
                    BorderBrush="#1A2A3A" BorderThickness="1" CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header aperçu -->
                    <Border Grid.Row="0" BorderBrush="#1A2A3A"
                            BorderThickness="0,0,0,1" Padding="16,0">
                        <Grid>
                            <TextBlock Text="APERÇU DU TICKET"
                                       FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                                       Foreground="#5A6A80" VerticalAlignment="Center"/>
                            <StackPanel x:Name="DownloadPanel" Orientation="Horizontal"
                                        HorizontalAlignment="Right" Visibility="Collapsed">
                                <Button Content="↓ Générer PNG"
                                        Style="{StaticResource BtnPrimary}"
                                        Padding="14,8" Margin="0,0,8,0"
                                        Click="BtnDownloadPng_Click"/>
                                <Button Content="↓ Aperçu JPG"
                                        Style="{StaticResource BtnSecondary}"
                                        Padding="14,8"
                                        Click="BtnDownloadJpg_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Image aperçu -->
                    <Border Grid.Row="1" Background="#0A0E14"
                            Margin="16" CornerRadius="6" ClipToBounds="True">
                        <Grid>
                            <!-- Loading -->
                            <StackPanel x:Name="LoadingPanel" Visibility="Collapsed"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="⟳" FontSize="36" Foreground="#00D4FF"
                                           HorizontalAlignment="Center"
                                           RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform x:Name="SpinTransform" Angle="0"/>
                                    </TextBlock.RenderTransform>
                                    <TextBlock.Triggers>
                                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="SpinTransform"
                                                        Storyboard.TargetProperty="Angle"
                                                        From="0" To="360"
                                                        Duration="0:0:1"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </TextBlock.Triggers>
                                </TextBlock>
                                <TextBlock Text="Génération en cours..."
                                           Foreground="#5A6A80" FontSize="12"
                                           HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            </StackPanel>

                            <!-- Image -->
                            <Image x:Name="PreviewImage" Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>

                            <!-- Badge modifié -->
                            <Border x:Name="ModifiedBadge" Visibility="Collapsed"
                                    Background="#00E5A0" CornerRadius="10"
                                    Padding="10,4" HorizontalAlignment="Right"
                                    VerticalAlignment="Top" Margin="0,10,10,0">
                                <TextBlock Text="✓ Modifié" FontFamily="Segoe UI"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="#090B0E"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Carte modifications -->
                    <Border x:Name="ChangesCard" Grid.Row="2" Visibility="Collapsed"
                            Background="#131920" BorderBrush="#1A2A3A"
                            BorderThickness="1" CornerRadius="6"
                            Margin="16,0,16,16" Padding="14,10">
                        <StackPanel>
                            <TextBlock Text="MODIFICATIONS APPLIQUÉES"
                                       FontFamily="Consolas" FontSize="9" FontWeight="Bold"
                                       Foreground="#5A6A80" Margin="0,0,0,10"/>
                            <UniformGrid x:Name="ChangesGrid" Columns="2"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ══ STATUS BAR ══ -->
        <Border Grid.Row="2" Background="#0D1117"
                BorderBrush="#1A2A3A" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Margin="24,0" VerticalAlignment="Center">
                <Ellipse x:Name="StatusBarDot" Width="6" Height="6"
                         Fill="#5A6A80" Margin="0,0,9,0"/>
                <TextBlock x:Name="StatusBarText" FontFamily="Consolas" FontSize="11"
                           Foreground="#5A6A80"
                           Text="Prêt — Configurez les données et cliquez sur Générer"/>
            </StackPanel>
        </Border>

        <!-- ══ BARRE LICENCE (bas, comme barre des tâches) ══ -->
        <!-- Height=0 par défaut → auto-expandée à 28px via code quand visible -->
        <Border x:Name="LicenseWarningBanner"
                Grid.Row="3"
                Visibility="Collapsed"
                Background="#1A0D00"
                BorderBrush="#FF8C00"
                BorderThickness="0,2,0,0"
                Height="28">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="⚠" FontSize="11"
                           Foreground="#FF8C00"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="LicenseWarningText"
                           Grid.Column="1"
                           FontFamily="Consolas" FontSize="10"
                           Foreground="#FF8C00" VerticalAlignment="Center"
                           Text="Votre licence expire bientôt."/>
            </Grid>
        </Border>

    </Grid> <!-- fin MainContent -->

        <!-- ══ OVERLAY MISE À JOUR BLOQUANT ══════════════════════════════════════
             Affiché PAR-DESSUS tout le contenu quand une mise à jour est prête.
             L'utilisateur ne peut PAS utiliser l'app tant qu'il n'a pas redémarré.
        ═══════════════════════════════════════════════════════════════════════ -->
        <Grid x:Name="UpdateOverlay"
              Visibility="Collapsed"
              Background="#CC000000"
              Panel.ZIndex="9999">
            <!-- Effet flou sur le contenu derrière -->
            <Grid.Effect>
                <BlurEffect Radius="0"/>
            </Grid.Effect>

            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#0D1117"
                    BorderBrush="#00CC66"
                    BorderThickness="2"
                    CornerRadius="8"
                    Padding="36,28"
                    MinWidth="460">
                <StackPanel>
                    <!-- Icône + Titre -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="✅" FontSize="28"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel>
                            <TextBlock Text="MISE À JOUR DISPONIBLE"
                                       FontFamily="Consolas" FontSize="15"
                                       FontWeight="Bold" Foreground="#00CC66"/>
                            <TextBlock x:Name="OverlayVersionLabel"
                                       FontFamily="Consolas" FontSize="10"
                                       Foreground="#555" Margin="0,3,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <Separator Background="#1A2A3A" Margin="0,8,0,12"/>

                    <!-- Message explicatif -->
                    <TextBlock Text="Une mise à jour est requise pour continuer à utiliser l'application."
                               FontFamily="Consolas" FontSize="10"
                               Foreground="#888" TextWrapping="Wrap"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="La mise à jour a été téléchargée automatiquement."
                               FontFamily="Consolas" FontSize="10"
                               Foreground="#888" TextWrapping="Wrap"
                               Margin="0,0,0,14"/>

                    <!-- Notes de version -->
                    <TextBlock Text="NOUVEAUTÉS" FontFamily="Consolas"
                               FontSize="9" Foreground="#444" Margin="0,0,0,5"/>
                    <Border Background="#0A1A0A" CornerRadius="4" Padding="10,8" Margin="0,0,0,16">
                        <ScrollViewer MaxHeight="100" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="OverlayNotesLabel"
                                       FontFamily="Consolas" FontSize="10"
                                       Foreground="#AAA" TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Border>

                    <!-- Barre de progression téléchargement -->
                    <Border x:Name="OverlayProgressPanel"
                            Visibility="Collapsed"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock x:Name="OverlayProgressLabel"
                                       Text="Téléchargement en cours..."
                                       FontFamily="Consolas" FontSize="9"
                                       Foreground="#00CC66" Margin="0,0,0,4"/>
                            <ProgressBar x:Name="OverlayProgressBar"
                                         Height="6" Minimum="0" Maximum="100" Value="0"
                                         Background="#1A1A1A" Foreground="#00CC66"
                                         BorderThickness="0"/>
                            <TextBlock x:Name="OverlaySizeLabel"
                                       FontFamily="Consolas" FontSize="8"
                                       Foreground="#444" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Bouton Redémarrer -->
                    <Button x:Name="OverlayRestartBtn"
                            Content="🔄  Redémarrer et installer la mise à jour"
                            FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                            Foreground="White" Background="#00CC66"
                            BorderThickness="0" Height="44"
                            Cursor="Hand"
                            IsEnabled="False"
                            Click="OverlayRestartBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="5" Padding="20,0"
                                        Opacity="{TemplateBinding IsEnabled, Converter={x:Static local:BoolToOpacityConverter.Instance}}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#009944"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <TextBlock x:Name="OverlayWaitLabel"
                               Text="⏳ Téléchargement en cours — veuillez patienter..."
                               FontFamily="Consolas" FontSize="9"
                               Foreground="#555" HorizontalAlignment="Center"
                               Margin="0,8,0,0" Visibility="Visible"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══ OVERLAY LICENCE EXPIRÉE (bloquant) ══════════════════════════════
             Apparaît à l'heure EXACTE d'expiration, pendant que l'app tourne.
             Bloque toute interaction. L'utilisateur doit renouveler pour continuer.
        ════════════════════════════════════════════════════════════════════════ -->
        <Grid x:Name="LicenseExpiredOverlay"
              Visibility="Collapsed"
              Background="#CC000000"
              Panel.ZIndex="9998">

            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#0D1117"
                    BorderBrush="#FF3333"
                    BorderThickness="2"
                    CornerRadius="8"
                    Padding="36,28"
                    MinWidth="440">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="🔒" FontSize="26"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel>
                            <TextBlock Text="LICENCE EXPIRÉE"
                                       FontFamily="Consolas" FontSize="15"
                                       FontWeight="Bold" Foreground="#FF3333"/>
                            <TextBlock Text="Votre accès a expiré. L'application est bloquée."
                                       FontFamily="Consolas" FontSize="10"
                                       Foreground="#888" Margin="0,3,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <Separator Background="#1A2A3A" Margin="0,4,0,14"/>

                    <TextBlock FontFamily="Consolas" FontSize="10"
                               Foreground="#AAA" TextWrapping="Wrap" Margin="0,0,0,20"
                               Text="Pour continuer à utiliser l'application, entrez votre nouvelle clé de licence ci-dessous."/>

                    <Button x:Name="BtnRenewLicense"
                            Content="🔑  Entrer ma nouvelle clé de licence"
                            FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                            Foreground="White" Background="#FF3333"
                            BorderThickness="0" Height="44"
                            Cursor="Hand"
                            Click="BtnRenewLicense_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="5" Padding="20,0">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#CC0000"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

    </Grid> <!-- fin RootGrid -->
</Window>
