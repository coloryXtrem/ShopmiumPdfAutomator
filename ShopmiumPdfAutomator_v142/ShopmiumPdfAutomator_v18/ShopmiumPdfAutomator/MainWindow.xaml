<Window x:Class="ShopmiumPdfAutomator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ShopmiumPdfAutomator"
        Title="⬡ Shopmium PDF Automator"
        Height="780" Width="1100"
        MinHeight="680" MinWidth="900"
        Background="#090B0E"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- Converter URL → BitmapImage pour vignettes offres -->
        <local:UrlToImageConverter x:Key="UrlToImage"/>

        <!-- Bool → Visibility (true=Visible, false=Collapsed) -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Style RadioButton onglet (défini ICI, pas dans App.xaml = pas de conflit) -->
        <Style x:Key="TabRadioStyle" TargetType="RadioButton">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" CornerRadius="4"
                                Background="Transparent" Padding="0,10">
                            <TextBlock x:Name="Lbl"
                                       Text="{TemplateBinding Content}"
                                       HorizontalAlignment="Center"
                                       FontFamily="Segoe UI" FontSize="12"
                                       FontWeight="SemiBold" Foreground="#5A6A80"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd"  Property="Background" Value="#1A2230"/>
                                <Setter TargetName="Lbl" Property="Foreground" Value="#00D4FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Lbl" Property="Foreground" Value="#8899AA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Filtre catégorie (boutons-onglets compacts pour la liste des offres) -->
        <Style x:Key="FilterTabStyle" TargetType="RadioButton">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="0,0,5,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" CornerRadius="12"
                                Background="#0F1620"
                                BorderBrush="#1A2A3A" BorderThickness="1"
                                Padding="9,4">
                            <TextBlock x:Name="Lbl"
                                       Text="{TemplateBinding Content}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Consolas" FontSize="9"
                                       FontWeight="SemiBold"
                                       Foreground="#7A8898"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd"  Property="Background"  Value="#003355"/>
                                <Setter TargetName="Bd"  Property="BorderBrush" Value="#00D4FF"/>
                                <Setter TargetName="Lbl" Property="Foreground"  Value="#00D4FF"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked"   Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd"  Property="Background"  Value="#162232"/>
                                <Setter TargetName="Lbl" Property="Foreground"  Value="#A0B0C0"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style boutons étapes EXIF (fond sombre, hover bleu) -->
        <Style x:Key="ExifBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="#0A2840"/>
            <Setter Property="Foreground"      Value="#88BBDD"/>
            <Setter Property="BorderBrush"     Value="#1A4060"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,7"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="#0F3858"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#00AACC"/>
                                <Setter Property="Foreground" Value="#AADDFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#062030"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style bouton principal du panneau EXIF (cyan vif pour le télécharger) -->
        <Style x:Key="ExifBtnPrimaryStyle" TargetType="Button" BasedOn="{StaticResource ExifBtnStyle}">
            <Setter Property="Background"      Value="#003060"/>
            <Setter Property="Foreground"      Value="#00D4FF"/>
            <Setter Property="BorderBrush"     Value="#00D4FF"/>
            <Setter Property="FontWeight"      Value="Bold"/>
        </Style>

        <!-- Bouton Primaire -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"      Value="#00D4FF"/>
            <Setter Property="Foreground"      Value="#090B0E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="20,12"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#20E0FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#00AACC"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bouton Secondaire -->
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background"      Value="#1A2230"/>
            <Setter Property="Foreground"      Value="#E8EDF5"/>
            <Setter Property="BorderBrush"     Value="#1A2A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="16,9"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#00D4FF"/>
                                <Setter Property="Foreground" Value="#00D4FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="#131920"/>
            <Setter Property="Foreground"      Value="#E8EDF5"/>
            <Setter Property="BorderBrush"     Value="#1A2A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,8"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="CaretBrush"      Value="#00D4FF"/>
            <Setter Property="SelectionBrush"  Value="#00D4FF"/>
        </Style>

        <!-- Style PasswordBox (mêmes valeurs que TextBox = harmonie) -->
        <Style TargetType="PasswordBox">
            <Setter Property="Background"      Value="#131920"/>
            <Setter Property="Foreground"      Value="#E8EDF5"/>
            <Setter Property="BorderBrush"     Value="#1A2A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,8"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="CaretBrush"      Value="#00D4FF"/>
            <Setter Property="SelectionBrush"  Value="#00D4FF"/>
        </Style>

        <!-- Style CheckBox sombre -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#A0B8D0"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Cursor"     Value="Hand"/>
        </Style>

        <!-- Style ComboBox avec ControlTemplate complet (fond sombre garanti) -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"      Value="#0A1520"/>
            <Setter Property="Foreground"      Value="#E8F0FF"/>
            <Setter Property="BorderBrush"     Value="#1A3050"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="#0A1520"
                                          BorderBrush="#1A3050"
                                          BorderThickness="1"
                                          Foreground="#E8F0FF"
                                          FontFamily="Consolas"
                                          FontSize="11"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen,
                                              Mode=TwoWay,
                                              RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Margin="6,4"
                                                                  HorizontalAlignment="Left"
                                                                  VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="▾"
                                                           Foreground="#446688"
                                                           FontSize="10"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,4,24,4"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder"
                                        Background="#0A1520"
                                        BorderBrush="#1A3050"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="200">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Style ComboBoxItem -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background"  Value="#0A1520"/>
            <Setter Property="Foreground"  Value="#E8F0FF"/>
            <Setter Property="FontFamily"  Value="Consolas"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="Padding"     Value="8,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A3050"/>
                                <Setter Property="Foreground" Value="#00D4FF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#003060"/>
                                <Setter Property="Foreground" Value="#00D4FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style Label -->
        <Style TargetType="Label">
            <Setter Property="Foreground"  Value="#5A6A80"/>
            <Setter Property="FontFamily"  Value="Consolas"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Padding"     Value="0,0,0,4"/>
        </Style>

        <!-- Style ListBox -->
        <Style TargetType="ListBox">
            <Setter Property="Background"      Value="#131920"/>
            <Setter Property="BorderBrush"     Value="#1A2A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"      Value="#E8EDF5"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="2"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding"     Value="10,7"/>
            <Setter Property="Foreground"  Value="#E8EDF5"/>
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="4"
                                Margin="2,1">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A2230"/>
                                <Setter Property="Foreground" Value="#00D4FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0F1820"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid x:Name="RootGrid">

        <!-- Contenu principal -->
        <Grid x:Name="MainContent">
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
            <RowDefinition x:Name="LicenseWarningRow" Height="0"/>
        </Grid.RowDefinitions>



        <!-- ══ HEADER ══ -->
        <Border Grid.Row="0" Background="#0D1117"
                BorderBrush="#1A2A3A" BorderThickness="0,0,0,1">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="⬡" FontSize="20" Foreground="#00D4FF"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock FontFamily="Segoe UI" FontSize="18" FontWeight="Bold"
                               VerticalAlignment="Center">
                        <Run Text="PDF" Foreground="#E8EDF5"/>
                        <Run Text="gen" Foreground="#00D4FF"/>
                        <Run Text=" v4" Foreground="#00D4FF" FontSize="11"/>
                    </TextBlock>
                </StackPanel>
                <Border Grid.Column="2" Background="#131920"
                        BorderBrush="#1A2A3A" BorderThickness="1"
                        CornerRadius="12" Padding="12,5" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Fill="#5A6A80"
                                 Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Carrefour Market • PDF Generator"
                                   FontFamily="Consolas" FontSize="11"
                                   Foreground="#5A6A80" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ══ CONTENU ══ -->
        <Grid Grid.Row="1" Margin="20,16,20,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="440"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── PANNEAU GAUCHE ── -->
            <Border Grid.Column="0" Background="#0D1117"
                    BorderBrush="#1A2A3A" BorderThickness="1" CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Onglets -->
                    <Border Grid.Row="0" Background="#131920"
                            Margin="12,12,12,0" CornerRadius="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <RadioButton x:Name="TabManuel"
                                         Grid.Column="0"
                                         Content="✎  Manuel"
                                         IsChecked="False"
                                         Visibility="Collapsed"
                                         Checked="Tab_Checked"
                                         Tag="Manual"
                                         GroupName="Tabs"
                                         Style="{StaticResource TabRadioStyle}"/>
                            <RadioButton x:Name="TabAuto"
                                         Grid.Column="1"
                                         Content="◈  Offres Shopmium"
                                         IsChecked="True"
                                         Checked="Tab_Checked"
                                         Tag="Auto"
                                         GroupName="Tabs"
                                         Style="{StaticResource TabRadioStyle}"/>
                            <RadioButton x:Name="TabSubmissions"
                                         Grid.Column="2"
                                         Content="📋  Mes soumissions"
                                         Checked="Tab_Checked"
                                         Tag="Submissions"
                                         GroupName="Tabs"
                                         Style="{StaticResource TabRadioStyle}"/>
                            <RadioButton x:Name="TabParams"
                                         Grid.Column="3"
                                         Content="⚙  Params"
                                         Checked="Tab_Checked"
                                         Tag="Params"
                                         GroupName="Tabs"
                                         Style="{StaticResource TabRadioStyle}"/>
                            <RadioButton x:Name="TabShopmiumApi"
                                         Grid.Column="4"
                                         Content="🚀  API (avancé)"
                                         Visibility="Collapsed"
                                         Checked="Tab_Checked"
                                         Tag="ShopmiumApi"
                                         GroupName="Tabs"
                                         Style="{StaticResource TabRadioStyle}"/>

                        </Grid>
                    </Border>

                    <!-- Contenu onglets -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  Background="Transparent">
                        <Grid Margin="16,12,16,16">

                            <!-- ═══ ONGLET MANUEL (caché — tout passe par l'API) ═══ -->
                            <StackPanel x:Name="PanelManuel" Visibility="Collapsed">

                                <TextBlock Text="INFORMATIONS PRODUIT"
                                           FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                                           Foreground="#5A6A80" Margin="0,0,0,12"/>

                                <Label Content="NOM DU PRODUIT"/>
                                <TextBox x:Name="InputProduct" Margin="0,0,0,4"
                                         Text="TOUCHER MAGIQUE 4D ULTRA CONFORT 6 RLX XL"/>
                                <TextBlock Text="Ligne 1 : 18 car. max  •  Ligne 2 : 22 car. max"
                                           FontFamily="Consolas" FontSize="10"
                                           Foreground="#5A6A80" Margin="0,0,0,14"/>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <Label Content="QUANTITÉ"/>
                                        <TextBox x:Name="InputQty" Text="5"
                                                 TextChanged="Calc_Changed"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <Label Content="PRIX UNITAIRE (€)"/>
                                        <TextBox x:Name="InputPrice" Text="3.99"
                                                 TextChanged="Calc_Changed"/>
                                    </StackPanel>
                                </Grid>

                                <Label Content="TAUX DE TVA"/>
                                <ComboBox x:Name="CbTva" Margin="0,0,0,12"
                                          SelectionChanged="Calc_Changed">
                                    <ComboBoxItem Tag="0.20" IsSelected="True"
                                                  Content="20 % — Alcool / Hygiène / Standard"/>
                                    <ComboBoxItem Tag="0.055"
                                                  Content="5,5 % — Alimentaire / Lait bébé"/>
                                    <ComboBoxItem Tag="0.10"
                                                  Content="10 % — Restauration"/>
                                </ComboBox>

                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#131920"
                                            BorderBrush="#1A2A3A" BorderThickness="1"
                                            CornerRadius="6" Padding="12,10">
                                        <StackPanel>
                                            <TextBlock Text="TOTAL TTC" FontFamily="Consolas"
                                                       FontSize="9" Foreground="#5A6A80"/>
                                            <TextBlock x:Name="LblTotal" Text="19.95 €"
                                                       FontFamily="Consolas" FontSize="16"
                                                       FontWeight="Bold" Foreground="#00D4FF"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Background="#131920"
                                            BorderBrush="#1A2A3A" BorderThickness="1"
                                            CornerRadius="6" Padding="12,10">
                                        <StackPanel>
                                            <TextBlock Text="TVA" FontFamily="Consolas"
                                                       FontSize="9" Foreground="#5A6A80"/>
                                            <TextBlock x:Name="LblTva" Text="1.99 €"
                                                       FontFamily="Consolas" FontSize="16"
                                                       FontWeight="Bold" Foreground="#00D4FF"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <TextBlock Text="DATE &amp; HEURE"
                                           FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                                           Foreground="#5A6A80" Margin="0,0,0,12"/>

                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <Label Content="DATE (JJ/MM/AAAA)"/>
                                        <TextBox x:Name="InputDate" Text="13/02/2026"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <Label Content="HEURE (vide = aléatoire)"/>
                                        <TextBox x:Name="InputTime" Text=""
                                                 ToolTip="Laisser vide pour une heure aléatoire"/>
                                    </StackPanel>
                                </Grid>

                                <Button x:Name="BtnGenerateManual"
                                        Content="⬡   GÉNÉRER LE PNG"
                                        Style="{StaticResource BtnPrimary}"
                                        Height="46" Click="BtnGenerateManual_Click"/>

                            </StackPanel>

                            <!-- ═══ ONGLET AUTO (alimenté par l'API Shopmium) ═══ -->
                            <StackPanel x:Name="PanelAuto" Visibility="Visible">

                                <Border Background="#131920" BorderBrush="#00D4FF"
                                        BorderThickness="0,0,0,1" Padding="0,0,0,12"
                                        Margin="0,0,0,16">
                                    <TextBlock TextWrapping="Wrap" FontSize="11"
                                               Foreground="#8899AA" LineHeight="18">
                                        Connectez-vous à votre compte Shopmium ci-dessous, puis sélectionnez une offre dans la liste pour générer son ticket automatiquement.
                                        Toutes les données (prix, quantité, TVA, image, EAN, enseignes) sont extraites directement depuis l'API officielle Shopmium.
                                    </TextBlock>
                                </Border>

                                <!-- ═══ ÉTAPE 1 — CONNEXION ═══ -->
                                <TextBlock Text="ÉTAPE 1 — CONNEXION SHOPMIUM"
                                           FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                                           Foreground="#5A6A80" Margin="0,0,0,8"/>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- EMAIL avec suggestions -->
                                    <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                        <TextBlock Text="EMAIL" FontSize="9"
                                                   FontFamily="Consolas" Foreground="#5A6A80"
                                                   Margin="0,0,0,3"/>
                                        <Grid>
                                            <!-- TextBox éditable classique : l'utilisateur tape librement -->
                                            <TextBox x:Name="ApiEmailCombo"
                                                     Height="32"
                                                     FontSize="11"
                                                     Padding="6,4"
                                                     GotFocus="ApiEmailCombo_GotFocus"
                                                     LostFocus="ApiEmailCombo_LostFocus"
                                                     TextChanged="ApiEmailCombo_TextChanged"
                                                     PreviewKeyDown="ApiEmailCombo_PreviewKeyDown"/>

                                            <!-- Popup d'autocomplétion : n'apparaît QUE si comptes mémorisés
                                                 correspondent au texte tapé (ou si le champ vient d'être cliqué) -->
                                            <Popup x:Name="ApiEmailSuggestionsPopup"
                                                   PlacementTarget="{Binding ElementName=ApiEmailCombo}"
                                                   Placement="Bottom"
                                                   StaysOpen="False"
                                                   AllowsTransparency="True"
                                                   PopupAnimation="Fade"
                                                   Width="{Binding ActualWidth, ElementName=ApiEmailCombo}">
                                                <Border Background="#131920"
                                                        BorderBrush="#1A2A3A"
                                                        BorderThickness="1"
                                                        CornerRadius="0,0,4,4">
                                                    <ListBox x:Name="ApiEmailSuggestionsList"
                                                             Background="Transparent"
                                                             BorderThickness="0"
                                                             MaxHeight="160"
                                                             Foreground="#C0D8F0"
                                                             FontSize="11"
                                                             PreviewMouseLeftButtonUp="ApiEmailSuggestionsList_PreviewMouseLeftButtonUp"
                                                             KeyDown="ApiEmailSuggestionsList_KeyDown">
                                                        <ListBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="4,3">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0"
                                                                               Text="{Binding}"
                                                                               VerticalAlignment="Center"/>
                                                                    <Button Grid.Column="1"
                                                                            Content="×"
                                                                            Tag="{Binding}"
                                                                            Width="20" Height="20"
                                                                            Background="Transparent"
                                                                            Foreground="#5A6A80"
                                                                            BorderThickness="0"
                                                                            FontSize="14"
                                                                            ToolTip="Supprimer ce compte"
                                                                            Click="BtnRemoveSavedAccount_Click"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ListBox.ItemTemplate>
                                                    </ListBox>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </StackPanel>

                                    <!-- MOT DE PASSE avec icône œil -->
                                    <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                        <TextBlock Text="MOT DE PASSE" FontSize="9"
                                                   FontFamily="Consolas" Foreground="#5A6A80"
                                                   Margin="0,0,0,3"/>
                                        <Grid Height="32">
                                            <Border Background="#131920" BorderBrush="#1A2A3A"
                                                    BorderThickness="1"/>
                                            <PasswordBox x:Name="ApiPassword"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         FontSize="13"
                                                         Padding="10,8,32,8"
                                                         PasswordChanged="ApiPassword_PasswordChanged"/>
                                            <TextBox x:Name="ApiPasswordVisible"
                                                     Visibility="Collapsed"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     FontSize="13"
                                                     Padding="10,8,32,8"
                                                     TextChanged="ApiPasswordVisible_TextChanged"/>
                                            <Button x:Name="BtnShowPassword"
                                                    Content="👁"
                                                    Width="28" Height="28"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,2,0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Foreground="#7A8A9A"
                                                    FontSize="13"
                                                    Cursor="Hand"
                                                    ToolTip="Afficher/masquer le mot de passe"
                                                    Click="BtnShowPassword_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>

                                <!-- Case "Se souvenir de moi" + Comptes enregistrés -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <CheckBox x:Name="ChkRememberMe"
                                              Grid.Column="0"
                                              Content="Se souvenir de moi"
                                              IsChecked="True"
                                              VerticalAlignment="Center"/>

                                    <Button x:Name="BtnSwitchAccount"
                                            Grid.Column="2"
                                            Content="↻ Changer de compte"
                                            Style="{StaticResource BtnSecondary}"
                                            FontSize="10"
                                            Padding="8,4"
                                            Visibility="Collapsed"
                                            Click="BtnSwitchAccount_Click"/>
                                </Grid>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Button x:Name="BtnApiLogin" Content="Se connecter"
                                            Style="{StaticResource BtnSecondary}"
                                            Click="BtnApiLogin_Click"
                                            Margin="0,0,8,0"/>
                                    <Button x:Name="BtnApiLogout" Content="Déconnecter"
                                            Style="{StaticResource BtnSecondary}"
                                            Visibility="Collapsed"
                                            Click="BtnApiLogout_Click"/>
                                </StackPanel>
                                <TextBlock x:Name="ApiLoginStatus" Text=""
                                           FontFamily="Consolas" FontSize="10"
                                           Foreground="#80A0C0" Margin="0,0,0,16"
                                           TextWrapping="Wrap"/>

                                <!-- ═══ ÉTAPE 2 — LISTE DES OFFRES ═══ -->
                                <TextBlock Text="ÉTAPE 2 — SÉLECTIONNER UNE OFFRE"
                                           FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                                           Foreground="#5A6A80" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button x:Name="BtnApiLoadOffers" Content="↻ Charger les offres"
                                            Style="{StaticResource BtnSecondary}"
                                            IsEnabled="False"
                                            Click="BtnApiLoadOffers_Click"
                                            Margin="0,0,12,0"/>
                                    <TextBlock x:Name="OfferCountLabel"
                                               VerticalAlignment="Center"
                                               FontFamily="Consolas" FontSize="10"
                                               Foreground="#80A0C0"/>
                                </StackPanel>

                                <ListBox x:Name="ApiOfferList" Height="220"
                                         SelectionChanged="ApiOfferList_SelectionChanged"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         Margin="0,0,0,16">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="64"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Vignette image produit (à gauche), ratio préservé -->
                                                <Border Grid.Column="0"
                                                        Width="56" Height="56"
                                                        Background="#FFFFFF"
                                                        BorderBrush="#1A3050"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Margin="0,0,10,0"
                                                        ClipToBounds="True">
                                                    <Image Source="{Binding EffectiveImageUrl,
                                                                   Converter={StaticResource UrlToImage}}"
                                                           Stretch="Uniform"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Margin="3"/>
                                                </Border>

                                                <!-- Nom + ligne d'incompatibilité éventuelle + statut soumission -->
                                                <StackPanel Grid.Column="1"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Foreground="#C0D8F0"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding IncompatibilityWarning}"
                                                               Visibility="{Binding HasIncompatibilityWarning,
                                                                            Converter={StaticResource BoolToVis}}"
                                                               Foreground="#FFAA44"
                                                               FontSize="10"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,2,0,0"/>
                                                    <!-- Badge de statut de soumission (en cours / refusée / annulée / etc.) -->
                                                    <TextBlock Text="{Binding StatusLabel}"
                                                               Visibility="{Binding HasStatusLabel,
                                                                            Converter={StaticResource BoolToVis}}"
                                                               Foreground="{Binding StatusBrush}"
                                                               FontSize="10"
                                                               FontWeight="Bold"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,3,0,0"/>
                                                    <TextBlock Text="{Binding StatusHelp}"
                                                               Visibility="{Binding HasStatusHelp,
                                                                            Converter={StaticResource BoolToVis}}"
                                                               Foreground="#7888A0"
                                                               FontSize="9"
                                                               FontStyle="Italic"
                                                               TextWrapping="Wrap"
                                                               Margin="0,1,0,0"/>
                                                </StackPanel>

                                                <!-- Colonne droite : % réduction + montant remboursé -->
                                                <StackPanel Grid.Column="2"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Right"
                                                            Margin="6,0,0,0">
                                                    <TextBlock Text="{Binding RebateSummary}"
                                                               Foreground="#00D4FF"
                                                               FontFamily="Consolas"
                                                               FontSize="11"
                                                               HorizontalAlignment="Right"/>
                                                    <TextBlock Text="{Binding EstimatedRebateLabel}"
                                                               Foreground="#00E5A0"
                                                               FontFamily="Consolas"
                                                               FontSize="10"
                                                               HorizontalAlignment="Right"
                                                               Margin="0,2,0,0"
                                                               Visibility="{Binding HasEstimatedRebate,
                                                                            Converter={StaticResource BoolToVis}}"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <!-- ═══ ÉTAPE 3 — DÉTAILS DE L'OFFRE SÉLECTIONNÉE ═══ -->
                                <Border x:Name="ApiOfferDetail" Visibility="Collapsed"
                                        Background="#0D1B2E" BorderBrush="#00D4FF"
                                        BorderThickness="1" CornerRadius="6"
                                        Padding="12" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock x:Name="ApiOfferName"
                                                   FontWeight="Bold" FontSize="12"
                                                   Foreground="#E8F0FF" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="ApiOfferBarcode"
                                                   FontFamily="Consolas" FontSize="10"
                                                   Foreground="#88AACC" Margin="0,0,0,2"/>
                                        <TextBlock x:Name="ApiOfferRetailers"
                                                   FontFamily="Consolas" FontSize="10"
                                                   Foreground="#88AACC"/>
                                    </StackPanel>
                                </Border>

                                <!-- (les éléments de cette ancienne section servent à
                                     compatibilité avec le code existant et restent cachés) -->
                                <ListBox x:Name="ProductList" Visibility="Collapsed" Height="0"/>
                                <TextBox x:Name="InputFavHtml" Visibility="Collapsed" Height="0"/>
                                <TextBox x:Name="InputProdHtml" Visibility="Collapsed" Height="0"/>
                                <TextBlock x:Name="LblStep3" Visibility="Collapsed"/>
                                <Button x:Name="BtnOpenProduct" Visibility="Collapsed"
                                        Click="BtnOpenProduct_Click"/>

                                <!-- Étape 4 -->
                                <TextBlock Text="ÉTAPE 4 — DONNÉES EXTRAITES"
                                           FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                                           Foreground="#5A6A80" Margin="0,0,0,8"/>
                                <!-- Panel sélection de référence (si pas de prix) -->
                                <Border x:Name="RefChoicePanel" Visibility="Collapsed"
                                        Background="#0D1B2E" BorderBrush="#FF8C00"
                                        BorderThickness="1" CornerRadius="6"
                                        Padding="12" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="⚠ PLUSIEURS RÉFÉRENCES — CHOISISSEZ UN PRODUIT"
                                                   FontFamily="Consolas" FontSize="9"
                                                   FontWeight="Bold" Foreground="#FF8C00"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="Aucun prix détecté. Sélectionnez la référence à mettre sur le ticket :"
                                                   FontFamily="Consolas" FontSize="9"
                                                   Foreground="#88AACC" TextWrapping="Wrap"
                                                   Margin="0,0,0,8"/>
                                        <ItemsControl x:Name="RefChoiceList">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Content="{Binding}"
                                                            Tag="{Binding}"
                                                            HorizontalAlignment="Stretch"
                                                            HorizontalContentAlignment="Left"
                                                            Margin="0,0,0,4" Padding="8,5"
                                                            FontFamily="Consolas" FontSize="9"
                                                            Background="#0A1520" Foreground="#00D4FF"
                                                            BorderBrush="#1A4060" BorderThickness="1"
                                                            Cursor="Hand"
                                                            Click="BtnRefChoice_Click"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- Bandeau "référence choisie" + bouton changer -->
                                <Border x:Name="RefChosenBar"
                                        Visibility="Collapsed"
                                        Background="#061A0A" BorderBrush="#1A5020"
                                        BorderThickness="1" CornerRadius="5"
                                        Padding="8,6" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="TbRefChosenName"
                                                   Grid.Column="0"
                                                   FontFamily="Consolas" FontSize="9"
                                                   Foreground="#4CC870"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="Wrap"/>
                                        <Button Grid.Column="1"
                                                Content="✏ Changer"
                                                Click="BtnChangeRef_Click"
                                                Height="24" Padding="8,0"
                                                Margin="8,0,0,0"
                                                FontFamily="Consolas" FontSize="8"
                                                Background="#0A1A10" Foreground="#88BBAA"
                                                BorderBrush="#1A4030" BorderThickness="1"
                                                Cursor="Hand"/>
                                    </Grid>
                                </Border>

                                <Border x:Name="ExtractedPanel" Visibility="Collapsed"
                                        Background="#131920" BorderBrush="#1A2A3A"
                                        BorderThickness="1" CornerRadius="6"
                                        Padding="12" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <!-- Labels -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,0,5"
                                                   Text="Produit" FontFamily="Consolas"
                                                   FontSize="10" Foreground="#5A6A80"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,0,5"
                                                   Text="Articles max" FontFamily="Consolas"
                                                   FontSize="10" Foreground="#5A6A80"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,0,5"
                                                   Text="Prix unitaire" FontFamily="Consolas"
                                                   FontSize="10" Foreground="#5A6A80"/>
                                        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,0,5"
                                                   Text="Total TTC" FontFamily="Consolas"
                                                   FontSize="10" Foreground="#5A6A80"/>
                                        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,0,5"
                                                   Text="TVA" FontFamily="Consolas"
                                                   FontSize="10" Foreground="#5A6A80"/>
                                        <TextBlock Grid.Row="5" Grid.Column="0"
                                                   Text="Date" FontFamily="Consolas"
                                                   FontSize="10" Foreground="#5A6A80"/>
                                        <!-- Valeurs -->
                                        <TextBlock x:Name="ExtProduit" Grid.Row="0" Grid.Column="1"
                                                   Margin="0,0,0,5" FontFamily="Consolas"
                                                   FontSize="10" Foreground="#00D4FF"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock x:Name="ExtArticles" Grid.Row="1" Grid.Column="1"
                                                   Margin="0,0,0,5" FontFamily="Consolas"
                                                   FontSize="10" Foreground="#00D4FF"/>
                                        <TextBlock x:Name="ExtPrix" Grid.Row="2" Grid.Column="1"
                                                   Margin="0,0,0,5" FontFamily="Consolas"
                                                   FontSize="10" Foreground="#00D4FF"/>
                                        <TextBlock x:Name="ExtTotal" Grid.Row="3" Grid.Column="1"
                                                   Margin="0,0,0,5" FontFamily="Consolas"
                                                   FontSize="10" Foreground="#00D4FF"/>
                                        <StackPanel Grid.Row="4" Grid.Column="1"
                                                            Margin="0,0,0,5">
                                            <TextBlock x:Name="ExtTva"
                                                       FontFamily="Consolas" FontSize="10"
                                                       Foreground="#00D4FF"
                                                       Margin="0,0,0,4"/>
                                            <ComboBox x:Name="CbAutoTva"
                                                      FontFamily="Consolas" FontSize="9"
                                                      Background="#0A1520"
                                                      Foreground="#E8F0FF"
                                                      BorderBrush="#1A3050"
                                                      SelectionChanged="CbAutoTva_SelectionChanged">
                                                <ComboBoxItem x:Name="CbAutoTvaAuto"
                                                              Tag="auto"
                                                              Content="Automatique"
                                                              IsSelected="True"/>
                                                <ComboBoxItem Tag="0.055" Content="5,5 %"/>
                                                <ComboBoxItem Tag="0.10"  Content="10,0 %"/>
                                                <ComboBoxItem Tag="0.20"  Content="20,0 %"/>
                                                <ComboBoxItem Tag="0.021" Content="2,1 %"/>
                                            </ComboBox>
                                        </StackPanel>
                                        <TextBlock x:Name="ExtDate" Grid.Row="5" Grid.Column="1"
                                                   FontFamily="Consolas" FontSize="10"
                                                   Foreground="#00D4FF"/>
                                    </Grid>
                                </Border>

                                <!-- ══ TYPE DE TICKET ══ -->
                                <Border x:Name="TicketTypePanel"
                                        Background="#0A1820" BorderBrush="#1A3050"
                                        BorderThickness="1" CornerRadius="6"
                                        Padding="10,8" Margin="0,0,0,10">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="🧾 TYPE DE TICKET"
                                                       FontFamily="Consolas" FontSize="9"
                                                       FontWeight="Bold" Foreground="#446688"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TbTicketTypeAuto"
                                                       FontFamily="Consolas" FontSize="9"
                                                       Foreground="#00D4FF"
                                                       VerticalAlignment="Center"
                                                       Margin="8,0,0,0" Text=""/>
                                        </StackPanel>

                                        <!-- Menu déroulant (toujours visible pour choix manuel) -->
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Forcer :"
                                                       FontFamily="Consolas" FontSize="8"
                                                       Foreground="#556688"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,6,0"/>
                                            <ComboBox x:Name="CbTicketType"
                                                      FontFamily="Consolas" FontSize="9"
                                                      Background="#081018" Foreground="#00D4FF"
                                                      BorderBrush="#1A4060"
                                                      Padding="6,3"
                                                      SelectionChanged="CbTicketType_SelectionChanged">
                                                <ComboBoxItem Tag="Standard"   Content="🧾 Ticket standard"/>
                                                <ComboBoxItem Tag="Leclerc"    Content="🟠 Ticket Leclerc"/>
                                                <ComboBoxItem Tag="CarrefourDrive" Content="🔵 Ticket Carrefour Drive"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <!-- Avertissement si mismatch -->
                                        <Border x:Name="TicketMismatchPanel"
                                                Visibility="Collapsed"
                                                Background="#1A0800" BorderBrush="#6B3000"
                                                BorderThickness="1" CornerRadius="4"
                                                Padding="6,5" Margin="0,6,0,0">
                                            <TextBlock x:Name="TbTicketMismatch"
                                                       FontFamily="Consolas" FontSize="8"
                                                       Foreground="#FF8C00"
                                                       TextWrapping="Wrap"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- ══ EAN-13 (toujours affiché) ══ -->
                                <Border x:Name="EanPanel"
                                        Visibility="Collapsed"
                                        Background="#0A1520" BorderBrush="#1A3050"
                                        BorderThickness="1" CornerRadius="6"
                                        Padding="10,10" Margin="0,0,0,10">
                                    <StackPanel>
                                        <!-- En-tête EAN-13 -->
                                        <TextBlock Text="EAN-13"
                                                   FontFamily="Consolas" FontSize="9"
                                                   FontWeight="Bold" Foreground="#446688"
                                                   Margin="0,0,0,6"/>

                                        <!-- Champ EAN + bouton inline -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Champ EAN éditable -->
                                            <TextBox x:Name="TbEanCode"
                                                     Grid.Column="0"
                                                     FontFamily="Consolas" FontSize="13"
                                                     FontWeight="Bold"
                                                     Foreground="#00D4FF"
                                                     Background="#081018"
                                                     BorderBrush="#1A4060"
                                                     BorderThickness="1"
                                                     Padding="6,4"
                                                     MaxLength="13"
                                                     Text=""
                                                     ToolTip="Code EAN-13 du produit"
                                                     TextChanged="TbEanCode_TextChanged"/>

                                            <!-- Afficher le code-barres prêt à scanner -->
                                            <Button Grid.Column="1"
                                                    x:Name="BtnGenerateBarcode"
                                                    Content="📊 Afficher le code-barres"
                                                    Margin="6,0,0,0" Padding="10,4"
                                                    FontFamily="Consolas" FontSize="10"
                                                    Background="#0A2040" Foreground="#00AACC"
                                                    BorderBrush="#1A4060" BorderThickness="1"
                                                    Cursor="Hand"
                                                    ToolTip="Afficher le code-barres sous forme d'image, prêt à scanner"
                                                    Click="BtnGenerateBarcode_Click"/>
                                        </Grid>

                                        <!-- Aperçu du code-barres : généré localement -->
                                        <Border x:Name="EanBarcodePanel"
                                                Visibility="Collapsed"
                                                Background="#FFFFFF"
                                                BorderBrush="#1A4060"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="10,8"
                                                Margin="0,8,0,0"
                                                HorizontalAlignment="Stretch">
                                            <StackPanel>
                                                <Image x:Name="EanBarcodeImage"
                                                       Stretch="Uniform"
                                                       MaxHeight="100"
                                                       Cursor="Hand"
                                                       HorizontalAlignment="Center"
                                                       ToolTip="Clic droit pour enregistrer ou copier l'image">
                                                    <Image.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="💾  Enregistrer sous..."
                                                                      Click="BtnSaveBarcode_Click"/>
                                                            <MenuItem Header="📋  Copier l'image"
                                                                      Click="BtnCopyBarcodeImage_Click"/>
                                                        </ContextMenu>
                                                    </Image.ContextMenu>
                                                </Image>
                                                <!-- EanBarcodeText caché : doublon avec ce qui est déjà
                                                     gravé sur l'image du code-barres lui-même -->
                                                <TextBlock x:Name="EanBarcodeText"
                                                           Visibility="Collapsed"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Message d'aide juste sous le panneau du code-barres,
                                             pas dans le Border blanc -->
                                        <TextBlock x:Name="BarcodeHelpText"
                                                   Visibility="Collapsed"
                                                   HorizontalAlignment="Center"
                                                   Foreground="#5A7088"
                                                   FontFamily="Consolas"
                                                   FontSize="10"
                                                   FontStyle="Italic"
                                                   Margin="0,8,0,0"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center">
                                            <Run Text="💡 "/>
                                            <Run Text="Clic droit" FontWeight="Bold"/>
                                            <Run Text=" sur le code-barres pour l'enregistrer ou le copier dans le presse-papiers."/>
                                        </TextBlock>

                                        <TextBlock x:Name="TbEanHint"
                                                   Visibility="Collapsed"
                                                   FontFamily="Consolas" FontSize="8"
                                                   Foreground="#334455" Margin="0,5,0,0"
                                                   TextWrapping="Wrap"
                                                   Text=""/>

                                        <!-- Boutons recherche cachés - tout est récupéré via l'API -->
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                                    Visibility="Collapsed">
                                            <Button x:Name="BtnSearchManual"
                                                    Content="🔍 Rechercher sur Auchan"
                                                    Padding="8,5"
                                                    Click="BtnSearchManual_Click"/>
                                            <Button x:Name="BtnSearchLeclerc"
                                                    Content="🔍 Rechercher sur Leclerc"
                                                    Padding="8,5"
                                                    Click="BtnSearchLeclerc_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- ══ EXIGENCES SUPPLÉMENTAIRES ══ -->
                                <Border x:Name="ProofPanel" Visibility="Collapsed"
                                        Background="#0D1B2E" BorderBrush="#1A4060"
                                        BorderThickness="1" CornerRadius="8"
                                        Padding="14,12" Margin="0,0,0,10">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock Text="📋" FontSize="13"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"/>
                                            <TextBlock Text="EXIGENCES SUPPLÉMENTAIRES"
                                                       FontFamily="Consolas" FontSize="10"
                                                       FontWeight="Bold" Foreground="#00D4FF"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock x:Name="TbProofCount"
                                                   FontFamily="Consolas" FontSize="9"
                                                   Foreground="#446688" Margin="0,0,0,8"/>
                                        <!-- Cartes exigences (générées en C#) -->
                                        <ItemsControl x:Name="ProofRequirementCards">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,10"
                                                            Background="#081018"
                                                            BorderBrush="#1A3050"
                                                            BorderThickness="1"
                                                            CornerRadius="6"
                                                            Padding="10,10">
                                                        <StackPanel>
                                                            <!-- Titre exigence -->
                                                            <TextBlock Text="{Binding Title}"
                                                                       FontFamily="Consolas"
                                                                       FontSize="10"
                                                                       FontWeight="Bold"
                                                                       Foreground="#E8F0FF"
                                                                       TextWrapping="Wrap"
                                                                       Margin="0,0,0,8"/>
                                                            <!-- Bouton Gemini (si disponible) -->
                                                            <Button Tag="{Binding GeminiUrl}"
                                                                    Content="{Binding BtnLabel}"
                                                                    Visibility="{Binding BtnVisibility}"
                                                                    Height="34" Margin="0,0,0,8"
                                                                    Padding="10,0"
                                                                    FontFamily="Consolas"
                                                                    FontSize="10"
                                                                    FontWeight="Bold"
                                                                    Background="#002850"
                                                                    Foreground="#4488FF"
                                                                    BorderBrush="#1A4080"
                                                                    BorderThickness="1"
                                                                    Cursor="Hand"
                                                                    Click="BtnOpenGemini_Click"/>
                                                            <!-- Prompt copiable -->
                                                            <TextBlock Text="Prompt à copier :"
                                                                       Visibility="{Binding PromptVisibility}"
                                                                       FontFamily="Consolas"
                                                                       FontSize="8"
                                                                       Foreground="#446688"
                                                                       Margin="0,0,0,4"/>
                                                            <Border Visibility="{Binding PromptVisibility}"
                                                                    Background="#040810"
                                                                    BorderBrush="#1A2A3A"
                                                                    BorderThickness="1"
                                                                    CornerRadius="4"
                                                                    Padding="8,6">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0"
                                                                               Text="{Binding Prompt}"
                                                                               FontFamily="Consolas"
                                                                               FontSize="9"
                                                                               Foreground="#88AACC"
                                                                               TextWrapping="Wrap"/>
                                                                    <Button Grid.Column="1"
                                                                            Tag="{Binding Prompt}"
                                                                            Content="📋"
                                                                            Width="28" Height="28"
                                                                            Margin="6,0,0,0"
                                                                            VerticalAlignment="Top"
                                                                            FontSize="13"
                                                                            Background="#0A1A30"
                                                                            Foreground="#88AACC"
                                                                            BorderBrush="#1A3050"
                                                                            BorderThickness="1"
                                                                            Cursor="Hand"
                                                                            ToolTip="Copier le prompt"
                                                                            Click="BtnCopyPrompt_Click"/>
                                                                </Grid>
                                                            </Border>
                                                            <!-- IMAGE SÉLECTIONNÉE AUTOMATIQUEMENT -->
                                                            <Border Visibility="{Binding BestImageVisibility}"
                                                                    Margin="0,10,0,0"
                                                                    Background="#060E18"
                                                                    BorderBrush="#1A3A60"
                                                                    BorderThickness="1"
                                                                    CornerRadius="6"
                                                                    Padding="10,8">
                                                                <StackPanel>
                                                                    <StackPanel Orientation="Horizontal"
                                                                                Margin="0,0,0,4">
                                                                        <TextBlock Text="🖼  IMAGE SÉLECTIONNÉE"
                                                                                   FontFamily="Consolas"
                                                                                   FontSize="8"
                                                                                   FontWeight="Bold"
                                                                                   Foreground="#446688"
                                                                                   VerticalAlignment="Center"/>
                                                                    </StackPanel>
                                                                    <!-- Aperçu image + bouton -->
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <!-- Miniature -->
                                                                        <Border Grid.Column="0"
                                                                                Width="80" Height="80"
                                                                                Background="#0A1520"
                                                                                BorderBrush="#1A3050"
                                                                                BorderThickness="1"
                                                                                CornerRadius="4"
                                                                                Margin="0,0,10,0">
                                                                            <Image Tag="{Binding BestImageUrl}"
                                                                                   Stretch="Uniform"
                                                                                   Loaded="BestProductImage_Loaded"/>
                                                                        </Border>
                                                                        <!-- Info + boutons -->
                                                                        <StackPanel Grid.Column="1"
                                                                                    VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding BestImageNote}"
                                                                                       FontFamily="Consolas"
                                                                                       FontSize="8"
                                                                                       Foreground="#5A7A9A"
                                                                                       TextWrapping="Wrap"
                                                                                       Margin="0,0,0,6"/>
                                                                            <!-- Avertissement si mismatch -->
                                                                            <TextBlock Visibility="{Binding WarnVisibility}"
                                                                                       Text="{Binding BestImageWarning}"
                                                                                       FontFamily="Consolas"
                                                                                       FontSize="8"
                                                                                       Foreground="#FFAA44"
                                                                                       TextWrapping="Wrap"
                                                                                       Margin="0,0,0,6"/>
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <Button Tag="{Binding BestImageData}"
                                                                                        Content="📥 Copier image"
                                                                                        Height="26" Padding="8,0"
                                                                                        FontFamily="Consolas"
                                                                                        FontSize="9"
                                                                                        Background="#002030"
                                                                                        Foreground="#28C840"
                                                                                        BorderBrush="#1A4030"
                                                                                        BorderThickness="1"
                                                                                        Cursor="Hand"
                                                                                        ToolTip="Copier l'image dans le presse-papier"
                                                                                        Click="BtnCopyImageData_Click"/>
                                                                            </StackPanel>
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </StackPanel>
                                                            </Border>

                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                                                <!-- ══ Avertissement EAN Drive : supprimé (EAN auto-rempli via API) ══ -->

                                                                <!-- Bannière TVA incertaine -->
                                                                <Border x:Name="TvaWarningPanel"
                                                                        Visibility="Collapsed"
                                                                        Background="#0D1A00"
                                                                        BorderBrush="#5A8A00"
                                                                        BorderThickness="1" CornerRadius="4"
                                                                        Padding="8,6" Margin="0,0,0,8">
                                                                    <StackPanel>
                                                                        <TextBlock x:Name="TvaWarningLabel"
                                                                                   Text="⚠ TVA estimée à 5,5% — produit non reconnu. Vérifiez ci-dessous."
                                                                                   FontFamily="Consolas" FontSize="8"
                                                                                   Foreground="#A8D400"
                                                                                   TextWrapping="Wrap"
                                                                                   Margin="0,0,0,4"/>
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <TextBlock Text="Taux TVA :"
                                                                                       FontFamily="Consolas" FontSize="8"
                                                                                       Foreground="#A8D400"
                                                                                       VerticalAlignment="Center"
                                                                                       Margin="0,0,6,0"/>
                                                                            <ComboBox x:Name="CbTvaWarning"
                                                                                      FontFamily="Consolas" FontSize="9"
                                                                                      Height="22" Width="100"
                                                                                      SelectionChanged="CbTvaWarning_SelectionChanged">
                                                                                <ComboBoxItem Tag="0.055" IsSelected="True">5,5% — Alimentaire</ComboBoxItem>
                                                                                <ComboBoxItem Tag="0.10">10% — Restauration</ComboBoxItem>
                                                                                <ComboBoxItem Tag="0.20">20% — Hygiène/Non-alim</ComboBoxItem>
                                                                                <ComboBoxItem Tag="0.021">2,1% — Médicament</ComboBoxItem>
                                                                            </ComboBox>
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                </Border>

                                                                <!-- ══════════════════════════════════════════════
                                                                     PANNEAU SUPPRESSION DES METADATA EXIF
                                                                     (image générée par Gemini)
                                                                ══════════════════════════════════════════════ -->
                                                                <Border x:Name="ExifPanel"
                                                                        Visibility="Collapsed"
                                                                        Background="#0A1A2A"
                                                                        BorderBrush="#FF8800"
                                                                        BorderThickness="1"
                                                                        CornerRadius="8"
                                                                        Padding="14,12"
                                                                        Margin="0,0,0,14">
                                                                    <StackPanel>
                                                                        <TextBlock Text="🛡️  NETTOYAGE DES METADATA (EXIF)"
                                                                                   FontFamily="Consolas" FontSize="11"
                                                                                   FontWeight="Bold" Foreground="#FFAA44"
                                                                                   Margin="0,0,0,6"/>

                                                                        <!-- Message explication utilisateur -->
                                                                        <TextBlock FontFamily="Consolas" FontSize="10"
                                                                                   Foreground="#C0D0E0"
                                                                                   TextWrapping="Wrap"
                                                                                   Margin="0,0,0,10">
                                                                            <Run Text="Pour que l'offre soit acceptée, retirez les metadata de l'image générée par Gemini."
                                                                                 FontWeight="Bold"/>
                                                                            <LineBreak/><LineBreak/>
                                                                            <Run Text="1) "/><Run Text="Importez" FontWeight="Bold"/><Run Text=" votre image Gemini"/>
                                                                            <LineBreak/>
                                                                            <Run Text="2) "/><Run Text="Cliquez sur " /><Run Text="Retirer les metadata" FontWeight="Bold"/>
                                                                            <LineBreak/>
                                                                            <Run Text="3) "/><Run Text="Cliquez sur " /><Run Text="Vérifier" FontWeight="Bold"/><Run Text=" pour confirmer la suppression"/>
                                                                            <LineBreak/>
                                                                            <Run Text="4) "/><Run Text="Téléchargez" FontWeight="Bold"/><Run Text=" l'image nettoyée"/>
                                                                        </TextBlock>

                                                                        <!-- Étape 1 : Importer -->
                                                                        <Button x:Name="BtnExifImport"
                                                                                Content="📥 Importer l'image générée par Gemini"
                                                                                Style="{StaticResource ExifBtnStyle}"
                                                                                Margin="0,0,0,6"
                                                                                Click="BtnExifImport_Click"/>

                                                                        <TextBlock x:Name="ExifImportedLabel"
                                                                                   Visibility="Collapsed"
                                                                                   FontFamily="Consolas" FontSize="9"
                                                                                   Foreground="#5AB878"
                                                                                   TextWrapping="Wrap"
                                                                                   Margin="0,0,0,6"/>

                                                                        <!-- Étape 2 : Retirer -->
                                                                        <Button x:Name="BtnExifClean"
                                                                                Content="🧹 Retirer les metadata"
                                                                                IsEnabled="False"
                                                                                Style="{StaticResource ExifBtnStyle}"
                                                                                Margin="0,0,0,6"
                                                                                Click="BtnExifClean_Click"/>

                                                                        <!-- Étape 3 : Vérifier -->
                                                                        <Button x:Name="BtnExifVerify"
                                                                                Content="🔍 Vérifier la suppression"
                                                                                IsEnabled="False"
                                                                                Style="{StaticResource ExifBtnStyle}"
                                                                                Margin="0,0,0,6"
                                                                                Click="BtnExifVerify_Click"/>

                                                                        <!-- Résultat de la vérification -->
                                                                        <Border x:Name="ExifVerifyPanel"
                                                                                Visibility="Collapsed"
                                                                                Background="#091624"
                                                                                BorderBrush="#1A4060"
                                                                                BorderThickness="1"
                                                                                CornerRadius="4"
                                                                                Padding="8,6"
                                                                                Margin="0,4,0,6">
                                                                            <TextBlock x:Name="ExifVerifyText"
                                                                                       FontFamily="Consolas" FontSize="9"
                                                                                       Foreground="#C0D0E0"
                                                                                       TextWrapping="Wrap"/>
                                                                        </Border>

                                                                        <!-- Étape 4 : Télécharger -->
                                                                        <Button x:Name="BtnExifSave"
                                                                                Content="💾 Télécharger l'image nettoyée"
                                                                                IsEnabled="False"
                                                                                Style="{StaticResource ExifBtnPrimaryStyle}"
                                                                                Click="BtnExifSave_Click"/>
                                                                    </StackPanel>
                                                                </Border>

                                                                <Button x:Name="BtnGenerateAuto"
                                        Content="⬡   GÉNÉRER LE PNG"
                                        Style="{StaticResource BtnPrimary}"
                                        Height="46" IsEnabled="False"
                                        Click="BtnGenerateAuto_Click"/>

                                                                <Button x:Name="BtnSubmitToShopmium"
                                        Content="📤   ENVOYER À SHOPMIUM"
                                        Style="{StaticResource ExifBtnStyle}"
                                        Height="38"
                                        Margin="0,10,0,0"
                                        IsEnabled="False"
                                        ToolTip="Envoie la demande de remboursement directement à Shopmium via l'API officielle. Une offre doit être sélectionnée."
                                        Click="BtnSubmitToShopmium_Click"/>
                            </StackPanel>

                            <!-- ═══ ONGLET MES SOUMISSIONS ═══ -->
                            <StackPanel x:Name="PanelSubmissions" Visibility="Collapsed">

                                <TextBlock Text="📋  MES SOUMISSIONS SHOPMIUM"
                                           FontFamily="Consolas" FontSize="11"
                                           FontWeight="Bold" Foreground="#00D4FF"
                                           Margin="0,0,0,12"/>

                                <!-- Header avec dashboard et bouton refresh -->
                                <Border Background="#0A1A2A" BorderBrush="#1A4060"
                                        BorderThickness="1" CornerRadius="6"
                                        Padding="14,10" Margin="0,0,0,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock x:Name="SubTotalRefunded"
                                                       FontFamily="Consolas" FontSize="14"
                                                       FontWeight="Bold" Foreground="#5AB878"
                                                       Text="Total remboursé : —"/>
                                            <TextBlock x:Name="SubTotalCount"
                                                       FontFamily="Consolas" FontSize="10"
                                                       Foreground="#88A8C8"
                                                       Text=""/>
                                        </StackPanel>
                                        <Button x:Name="BtnRefreshSubmissions"
                                                Grid.Column="1"
                                                Content="↻  Rafraîchir"
                                                Style="{StaticResource ExifBtnStyle}"
                                                Padding="14,7"
                                                Click="BtnRefreshSubmissions_Click"/>
                                    </Grid>
                                </Border>

                                <!-- Texte vide / loading -->
                                <TextBlock x:Name="SubEmptyText"
                                           Visibility="Visible"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="#7A8898"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="0,40,0,40"
                                           Text="Connectez-vous à Shopmium puis cliquez sur Rafraîchir pour voir votre historique."/>

                                <!-- Liste des soumissions -->
                                <ItemsControl x:Name="SubmissionsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#0F1620"
                                                    BorderBrush="#1A2A3A"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="14,12"
                                                    Margin="0,0,0,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="64"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Image offre -->
                                                    <Border Grid.Column="0"
                                                            Background="White"
                                                            CornerRadius="4"
                                                            Width="56" Height="56"
                                                            VerticalAlignment="Top">
                                                        <Image Source="{Binding MainCoupon.OfferImageUrl,
                                                                       Converter={StaticResource UrlToImage}}"
                                                               Stretch="Uniform"
                                                               Margin="3"/>
                                                    </Border>

                                                    <!-- Infos centrales -->
                                                    <StackPanel Grid.Column="1"
                                                                VerticalAlignment="Center"
                                                                Margin="12,0,12,0">
                                                        <TextBlock Text="{Binding MainCoupon.OfferTitle}"
                                                                   Foreground="#C0D8F0"
                                                                   FontFamily="Consolas"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding MainCoupon.StatusBadge}"
                                                                   Foreground="{Binding MainCoupon.StatusColor}"
                                                                   FontFamily="Consolas"
                                                                   FontSize="11"
                                                                   FontWeight="Bold"
                                                                   Margin="0,4,0,0"/>
                                                        <TextBlock Text="{Binding MainCoupon.StatusReason}"
                                                                   Foreground="#88A0B8"
                                                                   FontFamily="Consolas"
                                                                   FontSize="10"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,4,0,0"/>
                                                        <TextBlock Foreground="#5A7088"
                                                                   FontFamily="Consolas"
                                                                   FontSize="9"
                                                                   Margin="0,4,0,0">
                                                            <Run Text="Soumise le "/>
                                                            <Run Text="{Binding SubmittedDateFormatted, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </StackPanel>

                                                    <!-- Montant à droite + bouton "Envoyer une preuve" si applicable -->
                                                    <StackPanel Grid.Column="2"
                                                                VerticalAlignment="Center"
                                                                HorizontalAlignment="Right">
                                                        <TextBlock Text="{Binding MainCoupon.AmountFormatted}"
                                                                   Visibility="{Binding MainCoupon.HasAmount,
                                                                                Converter={StaticResource BoolToVis}}"
                                                                   Foreground="#5AB878"
                                                                   FontFamily="Consolas"
                                                                   FontSize="16"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Right"/>
                                                        <Button Content="📷 Envoyer une preuve"
                                                                Visibility="{Binding MainCoupon.CanAddProof,
                                                                             Converter={StaticResource BoolToVis}}"
                                                                Tag="{Binding}"
                                                                Click="BtnAddProofToSubmission_Click"
                                                                Style="{StaticResource ExifBtnStyle}"
                                                                Padding="10,5"
                                                                Margin="0,6,0,0"
                                                                HorizontalAlignment="Right"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- ═══ ONGLET PARAMS ═══ -->
                            <StackPanel x:Name="PanelParams" Visibility="Collapsed">

                                <TextBlock Text="PARAMÈTRES &amp; INFOS"
                                           FontFamily="Consolas" FontSize="10"
                                           FontWeight="Bold" Foreground="#00D4FF"
                                           Margin="0,0,0,16"/>

                                <!-- ── Bloc Discord ── -->
                                <Border Background="#0A1B2E" BorderBrush="#5865F2"
                                        BorderThickness="1" CornerRadius="8"
                                        Padding="14,12" Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="💬  COMMUNAUTÉ &amp; SUPPORT"
                                                   FontFamily="Consolas" FontSize="10"
                                                   FontWeight="Bold" Foreground="#5865F2"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="Rejoignez le serveur Discord pour le support, les annonces et les retours."
                                                   FontFamily="Consolas" FontSize="10"
                                                   Foreground="#7A8A9A"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,10"/>
                                        <Button x:Name="BtnOpenDiscord"
                                                Content="🔗  Ouvrir le serveur Discord"
                                                Height="34"
                                                Background="#5865F2"
                                                Foreground="#FFFFFF"
                                                BorderThickness="0"
                                                FontFamily="Consolas"
                                                FontSize="11"
                                                FontWeight="Bold"
                                                Cursor="Hand"
                                                Click="BtnOpenDiscord_Click"/>
                                    </StackPanel>
                                </Border>

                                <!-- ── Bloc État API ── -->
                                <Border Background="#0D1B2E" BorderBrush="#1A3050"
                                        BorderThickness="1" CornerRadius="8"
                                        Padding="14,12" Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="🔌  ÉTAT API SHOPMIUM"
                                                   FontFamily="Consolas" FontSize="10"
                                                   FontWeight="Bold" Foreground="#00D4FF"
                                                   Margin="0,0,0,10"/>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Statut : "
                                                       FontFamily="Consolas" FontSize="11"
                                                       Foreground="#7A8A9A"/>
                                            <TextBlock Grid.Column="1"
                                                       x:Name="ParamsApiStatus"
                                                       FontFamily="Consolas" FontSize="11"
                                                       Foreground="#FFAA44"
                                                       Text="Non connecté"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Compte : "
                                                       FontFamily="Consolas" FontSize="11"
                                                       Foreground="#7A8A9A"/>
                                            <TextBlock Grid.Column="1"
                                                       x:Name="ParamsApiAccount"
                                                       FontFamily="Consolas" FontSize="11"
                                                       Foreground="#C0D8F0"
                                                       Text="—"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Offres : "
                                                       FontFamily="Consolas" FontSize="11"
                                                       Foreground="#7A8A9A"/>
                                            <TextBlock Grid.Column="1"
                                                       x:Name="ParamsApiOffersCount"
                                                       FontFamily="Consolas" FontSize="11"
                                                       Foreground="#C0D8F0"
                                                       Text="—"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- ── Bloc Licence ── -->
                                <Border Background="#0D1B2E" BorderBrush="#1A3050"
                                        BorderThickness="1" CornerRadius="8"
                                        Padding="14,12" Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="🔑  LICENCE"
                                                   FontFamily="Consolas" FontSize="10"
                                                   FontWeight="Bold" Foreground="#00D4FF"
                                                   Margin="0,0,0,10"/>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Type : "
                                                       FontFamily="Consolas" FontSize="11"
                                                       Foreground="#7A8A9A"/>
                                            <TextBlock Grid.Column="1"
                                                       x:Name="ParamsLicenseType"
                                                       FontFamily="Consolas" FontSize="11"
                                                       Foreground="#C0D8F0"
                                                       Text="—"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Expire : "
                                                       FontFamily="Consolas" FontSize="11"
                                                       Foreground="#7A8A9A"/>
                                            <TextBlock Grid.Column="1"
                                                       x:Name="ParamsLicenseExpiry"
                                                       FontFamily="Consolas" FontSize="11"
                                                       Foreground="#C0D8F0"
                                                       Text="—"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- ── Bloc Outils / cache ── -->
                                <Border Background="#0D1B2E" BorderBrush="#1A3050"
                                        BorderThickness="1" CornerRadius="8"
                                        Padding="14,12" Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="🧹  MAINTENANCE"
                                                   FontFamily="Consolas" FontSize="10"
                                                   FontWeight="Bold" Foreground="#00D4FF"
                                                   Margin="0,0,0,10"/>
                                        <Button x:Name="BtnClearIdentityHistory"
                                                Content="Réinitialiser les identités générées"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Left"
                                                Padding="10,7"
                                                Background="#0A1820"
                                                Foreground="#88AACC"
                                                BorderBrush="#1A3050"
                                                BorderThickness="1"
                                                FontFamily="Consolas" FontSize="10"
                                                Cursor="Hand"
                                                Margin="0,0,0,6"
                                                Click="BtnClearIdentityHistory_Click"/>
                                        <Button x:Name="BtnClearSavedAccounts"
                                                Content="Effacer tous les comptes mémorisés"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Left"
                                                Padding="10,7"
                                                Background="#0A1820"
                                                Foreground="#88AACC"
                                                BorderBrush="#1A3050"
                                                BorderThickness="1"
                                                FontFamily="Consolas" FontSize="10"
                                                Cursor="Hand"
                                                Click="BtnClearSavedAccounts_Click"/>
                                    </StackPanel>
                                </Border>

                                <!-- ── À propos ── -->
                                <Border Background="#0A1015" BorderBrush="#1A2530"
                                        BorderThickness="1" CornerRadius="8"
                                        Padding="14,12">
                                    <StackPanel>
                                        <TextBlock Text="ℹ  À PROPOS"
                                                   FontFamily="Consolas" FontSize="10"
                                                   FontWeight="Bold" Foreground="#446688"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="Shopmium PDF Automator"
                                                   FontFamily="Consolas" FontSize="10"
                                                   Foreground="#334455" Margin="0,0,0,3"/>
                                        <TextBlock x:Name="ParamsVersion"
                                                   Text="Version : —"
                                                   FontFamily="Consolas" FontSize="10"
                                                   Foreground="#334455" Margin="0,0,0,3"/>
                                        <TextBlock Text="Moteur : Adobe Photoshop CC"
                                                   FontFamily="Consolas" FontSize="10"
                                                   Foreground="#334455" Margin="0,0,0,3"/>
                                        <TextBlock Text="Source données : API Shopmium officielle"
                                                   FontFamily="Consolas" FontSize="10"
                                                   Foreground="#334455"/>
                                    </StackPanel>
                                </Border>

                            </StackPanel>


                            <!-- ═══ ONGLET CHAT IA ═══ -->
                            <Grid x:Name="PanelChat" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- ── BLOC CONTEXTE PRODUIT ── -->
                                <Border x:Name="ChatContextPanel"
                                        Grid.Row="0"
                                        Background="#0A1A2A"
                                        BorderBrush="#1A3050"
                                        BorderThickness="1" CornerRadius="8"
                                        Padding="12,10" Margin="0,0,0,10"
                                        Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Text="📋  CONTEXTE PRODUIT CHARGÉ"
                                                   FontFamily="Consolas" FontSize="9"
                                                   FontWeight="Bold" Foreground="#00D4FF"
                                                   Margin="0,0,0,8"/>

                                        <!-- Exigences Shopmium -->
                                        <Border x:Name="ChatRequirementsPanel"
                                                Background="#061018"
                                                BorderBrush="#1A2A3A"
                                                BorderThickness="1" CornerRadius="6"
                                                Padding="10,8" Margin="0,0,0,8"
                                                Visibility="Collapsed">
                                            <StackPanel>
                                                <TextBlock Text="EXIGENCES DÉTECTÉES"
                                                           FontFamily="Consolas" FontSize="8"
                                                           Foreground="#446688"
                                                           FontWeight="Bold"
                                                           Margin="0,0,0,6"/>
                                                <ItemsControl x:Name="ChatRequirementsList">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}"
                                                                       FontFamily="Consolas"
                                                                       FontSize="10"
                                                                       Foreground="#88BBDD"
                                                                       TextWrapping="Wrap"
                                                                       Margin="0,2,0,2"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>

                                        <!-- Infos produit + TVA -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Résumé produit -->
                                            <StackPanel Grid.Column="0">
                                                <TextBlock x:Name="TbChatProductName"
                                                           FontFamily="Consolas" FontSize="10"
                                                           FontWeight="Bold"
                                                           Foreground="#E8F0FF"
                                                           TextWrapping="Wrap"
                                                           Text=""/>
                                                <TextBlock x:Name="TbChatProductDetails"
                                                           FontFamily="Consolas" FontSize="9"
                                                           Foreground="#556677"
                                                           TextWrapping="Wrap"
                                                           Margin="0,2,0,0"
                                                           Text=""/>
                                            </StackPanel>

                                            <!-- Menu TVA -->
                                            <StackPanel Grid.Column="1"
                                                        Margin="10,0,0,0"
                                                        VerticalAlignment="Top">
                                                <TextBlock Text="TVA"
                                                           FontFamily="Consolas" FontSize="8"
                                                           Foreground="#446688"
                                                           Margin="0,0,0,4"/>
                                                <ComboBox x:Name="CbChatTva"
                                                          Width="90"
                                                          FontFamily="Consolas"
                                                          FontSize="10"
                                                          Background="#0A1520"
                                                          Foreground="#E8F0FF"
                                                          BorderBrush="#1A3050"
                                                          SelectionChanged="CbChatTva_SelectionChanged">
                                                    <ComboBoxItem Tag="0.20" Content="20,0 %"/>
                                                    <ComboBoxItem Tag="0.10" Content="10,0 %"/>
                                                    <ComboBoxItem Tag="0.055" Content="5,5 %"/>
                                                    <ComboBoxItem Tag="0.021" Content="2,1 %"/>
                                                </ComboBox>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Image produit -->
                                        <Border Margin="0,8,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <!-- Aperçu image si chargée -->
                                                <Border x:Name="ChatImagePreview"
                                                        Width="60" Height="60"
                                                        Background="#061018"
                                                        BorderBrush="#1A3050"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Margin="0,0,10,0"
                                                        Visibility="Collapsed">
                                                    <Image x:Name="ChatProductThumb"
                                                           Stretch="Uniform"/>
                                                </Border>

                                                <StackPanel VerticalAlignment="Center">
                                                    <Button x:Name="BtnChatImportImage"
                                                            Content="📎  Importer image produit"
                                                            Height="30" Padding="10,0"
                                                            Click="BtnChatImportImage_Click"
                                                            FontFamily="Consolas" FontSize="9"
                                                            Background="#0A2040"
                                                            Foreground="#00D4FF"
                                                            BorderBrush="#1A4060"
                                                            BorderThickness="1"
                                                            Cursor="Hand"
                                                            Margin="0,0,0,4"/>
                                                    <TextBlock x:Name="TbChatImageStatus"
                                                               FontFamily="Consolas" FontSize="8"
                                                               Foreground="#446688"
                                                               Text="Pas d'image — GPT utilisera le nom du produit"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- ── EN-TÊTE CHAT ── -->
                                <StackPanel Grid.Row="1" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="CHAT GPT-4o"
                                                   FontFamily="Consolas" FontSize="10"
                                                   FontWeight="Bold" Foreground="#5A6A80"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TbChatModel"
                                                   FontFamily="Consolas" FontSize="9"
                                                   Foreground="#334455"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0"
                                                   Text="— gpt-4o"/>
                                        <Button x:Name="BtnClearChat"
                                                Content="🗑  Nouvelle conversation"
                                                Height="22" Margin="12,0,0,0"
                                                Padding="8,0"
                                                Click="BtnClearChat_Click"
                                                FontFamily="Consolas" FontSize="9"
                                                Background="#1A1A2A"
                                                Foreground="#556688"
                                                BorderBrush="#2A3A4A"
                                                Cursor="Hand"/>
                                        <Button x:Name="BtnInjectContext"
                                                Content="⤵  Injecter contexte produit"
                                                Height="22" Margin="8,0,0,0"
                                                Padding="8,0"
                                                Click="BtnInjectContext_Click"
                                                FontFamily="Consolas" FontSize="9"
                                                Background="#002040"
                                                Foreground="#00AACC"
                                                BorderBrush="#1A3050"
                                                Cursor="Hand"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- ── ZONE CHAT ── -->
                                <Grid Grid.Row="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Historique messages -->
                                    <Border Grid.Row="0"
                                            Background="#080E18"
                                            BorderBrush="#1A2A3A"
                                            BorderThickness="1" CornerRadius="8"
                                            Margin="0,0,0,8"
                                            MinHeight="300">
                                        <ScrollViewer x:Name="ChatScrollViewer"
                                                      VerticalScrollBarVisibility="Auto"
                                                      Padding="10,8">
                                            <ItemsControl x:Name="ChatMessages">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,0,8"
                                                                Padding="10,8"
                                                                CornerRadius="6"
                                                                Background="{Binding Background}">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Sender}"
                                                                           FontFamily="Consolas"
                                                                           FontSize="8"
                                                                           FontWeight="Bold"
                                                                           Foreground="{Binding SenderColor}"
                                                                           Margin="0,0,0,4"/>
                                                                <TextBlock Text="{Binding Content}"
                                                                           FontFamily="Consolas"
                                                                           FontSize="11"
                                                                           Foreground="#D0E0FF"
                                                                           TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>

                                    <!-- Zone de saisie -->
                                    <Grid Grid.Row="1" Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="TbChatInput"
                                                 Grid.Column="0"
                                                 Height="70"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 FontFamily="Consolas" FontSize="11"
                                                 Background="#0A1520"
                                                 Foreground="#E8F0FF"
                                                 BorderBrush="#1A3050"
                                                 Padding="8,6"
                                                 ToolTip="Ctrl+Entrée = envoyer"
                                                 KeyDown="TbChatInput_KeyDown"
                                                 Margin="0,0,8,0"/>
                                        <Button x:Name="BtnSendChat"
                                                Grid.Column="1"
                                                Width="70" Height="70"
                                                Click="BtnSendChat_Click"
                                                Cursor="Hand"
                                                Background="#003060"
                                                BorderBrush="#006090"
                                                BorderThickness="1">
                                            <TextBlock Text="➤"
                                                       FontSize="22"
                                                       Foreground="#00D4FF"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Button>
                                    </Grid>

                                    <!-- Hints -->
                                    <TextBlock Grid.Row="2"
                                               Text="Ctrl+Entrée pour envoyer  •  Si image importée, elle est envoyée avec votre prochain message"
                                               FontFamily="Consolas" FontSize="8"
                                               Foreground="#334455"
                                               HorizontalAlignment="Center"/>
                                </Grid>
                            </Grid>


                            <!-- ══════════════════════════════════════════════
                                 PANNEAU API SHOPMIUM
                            ═══════════════════════════════════════════════ -->
                            <StackPanel x:Name="PanelShopmiumApi" Visibility="Collapsed">

                                <!-- Connexion -->
                                <TextBlock Text="🔐 Connexion Shopmium"
                                           Foreground="#A0B8D0" FontSize="11"
                                           FontWeight="SemiBold" Margin="0,0,0,6"/>

                                <Border Background="#0A1520" BorderBrush="#1A3050"
                                        BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Email" Foreground="#607080"
                                                   FontSize="10" Margin="0,0,0,4"/>
                                        <TextBox x:Name="ApiEmail_Old" Margin="0,0,0,8"
                                                 Height="32" FontSize="12"/>

                                        <TextBlock Text="Mot de passe" Foreground="#607080"
                                                   FontSize="10" Margin="0,0,0,4"/>
                                        <PasswordBox x:Name="ApiPassword_Old" Margin="0,0,0,10"
                                                     Height="32" FontSize="12"
                                                     Background="#131920" Foreground="White"
                                                     BorderBrush="#1A3050"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="ApiLoginStatus_Old"
                                                       Grid.Column="0"
                                                       Text="Non connecté"
                                                       Foreground="#607080" FontSize="11"
                                                       VerticalAlignment="Center"/>
                                            <Button x:Name="BtnApiLogin_Old"
                                                    Grid.Column="1"
                                                    Content="Se connecter"
                                                    Style="{StaticResource BtnPrimary}"
                                                    Padding="14,6"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Offres -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="📦 Offres disponibles"
                                               Foreground="#A0B8D0" FontSize="11"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <Button x:Name="BtnApiLoadOffers_Old"
                                            Grid.Column="1"
                                            Content="↻ Charger"
                                            Style="{StaticResource BtnSecondary}"
                                            Padding="10,4" IsEnabled="False"/>
                                </Grid>

                                <ListBox x:Name="ApiOfferList_Old"
                                         Height="130"
                                         Background="#0A1520"
                                         BorderBrush="#1A3050"
                                         Foreground="#C0D8F0"
                                         FontSize="11"
                                         Margin="0,0,0,8"/>

                                <!-- Détails offre sélectionnée -->
                                <Border x:Name="ApiOfferDetail_Old" Visibility="Collapsed"
                                        Background="#0A1520" BorderBrush="#1A4060"
                                        BorderThickness="1" CornerRadius="6"
                                        Padding="10" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock x:Name="ApiOfferName_Old"
                                                   Foreground="#00AAFF" FontSize="12"
                                                   FontWeight="SemiBold" TextWrapping="Wrap"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock x:Name="ApiOfferBarcode_Old"
                                                   Foreground="#80A0C0" FontSize="11"
                                                   Margin="0,0,0,2"/>
                                        <TextBlock x:Name="ApiOfferRetailers_Old"
                                                   Foreground="#80A0C0" FontSize="11"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <!-- Soumission -->
                                <TextBlock Text="🚀 Soumettre à Shopmium"
                                           Foreground="#A0B8D0" FontSize="11"
                                           FontWeight="SemiBold" Margin="0,0,0,6"/>

                                <Border Background="#0A1520" BorderBrush="#1A3050"
                                        BorderThickness="1" CornerRadius="6"
                                        Padding="12" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="Image à soumettre" Foreground="#607080"
                                                   FontSize="10" Margin="0,0,0,4"/>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="ApiImagePath"
                                                       Text="Aucune image sélectionnée"
                                                       Foreground="#607080" FontSize="10"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Button Grid.Column="1" Content="Parcourir…"
                                                    Style="{StaticResource BtnSecondary}"
                                                    Padding="8,4"
                                                    Click="BtnApiPickImage_Click"/>
                                        </Grid>

                                        <TextBlock Text="Enseigne (optionnel)"
                                                   Foreground="#607080" FontSize="10"
                                                   Margin="0,0,0,4"/>
                                        <TextBox x:Name="ApiChain"
                                                 Height="30" FontSize="12"
                                                 Margin="0,0,0,10"
                                                 ToolTip="Ex: CARREFOUR, LECLERC, INTERMARCHE…"/>

                                        <Button x:Name="BtnApiSubmit"
                                                Content="🚀  Soumettre le ticket"
                                                Style="{StaticResource BtnPrimary}"
                                                Height="40" IsEnabled="False"
                                                Click="BtnApiSubmit_Click"/>

                                        <TextBlock x:Name="ApiSubmitStatus"
                                                   Text="" Foreground="#00E5A0"
                                                   FontSize="11" TextWrapping="Wrap"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </Grid>

                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ── PANNEAU DROIT : Aperçu ── -->
            <Border Grid.Column="2" Background="#0D1117"
                    BorderBrush="#1A2A3A" BorderThickness="1" CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header aperçu -->
                    <Border Grid.Row="0" BorderBrush="#1A2A3A"
                            BorderThickness="0,0,0,1" Padding="16,0">
                        <Grid>
                            <TextBlock Text="APERÇU DU TICKET"
                                       FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                                       Foreground="#5A6A80" VerticalAlignment="Center"/>
                            <StackPanel x:Name="DownloadPanel" Orientation="Horizontal"
                                        HorizontalAlignment="Right" Visibility="Collapsed">
                                <Button Content="↓ Générer PNG"
                                        Style="{StaticResource BtnPrimary}"
                                        Padding="14,8" Margin="0,0,8,0"
                                        Click="BtnDownloadPng_Click"/>
                                <Button Content="↓ Aperçu JPG"
                                        Style="{StaticResource BtnSecondary}"
                                        Padding="14,8"
                                        Click="BtnDownloadJpg_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Image aperçu -->
                    <Border Grid.Row="1" Background="#0A0E14"
                            Margin="16" CornerRadius="6" ClipToBounds="True">
                        <Grid>
                            <!-- Loading -->
                            <StackPanel x:Name="LoadingPanel" Visibility="Collapsed"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="⟳" FontSize="36" Foreground="#00D4FF"
                                           HorizontalAlignment="Center"
                                           RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform x:Name="SpinTransform" Angle="0"/>
                                    </TextBlock.RenderTransform>
                                    <TextBlock.Triggers>
                                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="SpinTransform"
                                                        Storyboard.TargetProperty="Angle"
                                                        From="0" To="360"
                                                        Duration="0:0:1"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </TextBlock.Triggers>
                                </TextBlock>
                                <TextBlock Text="Génération en cours..."
                                           Foreground="#5A6A80" FontSize="12"
                                           HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            </StackPanel>

                            <!-- Image -->
                            <Image x:Name="PreviewImage" Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>

                            <!-- Badge modifié -->
                            <Border x:Name="ModifiedBadge" Visibility="Collapsed"
                                    Background="#00E5A0" CornerRadius="10"
                                    Padding="10,4" HorizontalAlignment="Right"
                                    VerticalAlignment="Top" Margin="0,10,10,0">
                                <TextBlock Text="✓ Modifié" FontFamily="Segoe UI"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="#090B0E"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Carte modifications -->
                    <Border x:Name="ChangesCard" Grid.Row="2" Visibility="Collapsed"
                            Background="#131920" BorderBrush="#1A2A3A"
                            BorderThickness="1" CornerRadius="6"
                            Margin="16,0,16,16" Padding="14,10">
                        <StackPanel>
                            <TextBlock Text="MODIFICATIONS APPLIQUÉES"
                                       FontFamily="Consolas" FontSize="9" FontWeight="Bold"
                                       Foreground="#5A6A80" Margin="0,0,0,10"/>
                            <UniformGrid x:Name="ChangesGrid" Columns="2"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ══ STATUS BAR ══ -->
        <Border Grid.Row="2" Background="#0D1117"
                BorderBrush="#1A2A3A" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Margin="24,0" VerticalAlignment="Center">
                <Ellipse x:Name="StatusBarDot" Width="6" Height="6"
                         Fill="#5A6A80" Margin="0,0,9,0"/>
                <TextBlock x:Name="StatusBarText" FontFamily="Consolas" FontSize="11"
                           Foreground="#5A6A80"
                           Text="Prêt — Configurez les données et cliquez sur Générer"/>
            </StackPanel>
        </Border>

        <!-- ══ BARRE LICENCE (bas, comme barre des tâches) ══ -->
        <!-- Height=0 par défaut → auto-expandée à 28px via code quand visible -->
        <Border x:Name="LicenseWarningBanner"
                Grid.Row="3"
                Visibility="Collapsed"
                Background="#1A0D00"
                BorderBrush="#FF8C00"
                BorderThickness="0,2,0,0"
                Height="28">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="⚠" FontSize="11"
                           Foreground="#FF8C00"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="LicenseWarningText"
                           Grid.Column="1"
                           FontFamily="Consolas" FontSize="10"
                           Foreground="#FF8C00" VerticalAlignment="Center"
                           Text="Votre licence expire bientôt."/>
            </Grid>
        </Border>

    </Grid> <!-- fin MainContent -->

        <!-- ══ OVERLAY MISE À JOUR BLOQUANT ══════════════════════════════════════
             Affiché PAR-DESSUS tout le contenu quand une mise à jour est prête.
             L'utilisateur ne peut PAS utiliser l'app tant qu'il n'a pas redémarré.
        ═══════════════════════════════════════════════════════════════════════ -->
        <Grid x:Name="UpdateOverlay"
              Visibility="Collapsed"
              Background="#CC000000"
              Panel.ZIndex="9999">
            <!-- Effet flou sur le contenu derrière -->
            <Grid.Effect>
                <BlurEffect Radius="0"/>
            </Grid.Effect>

            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#0D1117"
                    BorderBrush="#00CC66"
                    BorderThickness="2"
                    CornerRadius="8"
                    Padding="36,28"
                    MinWidth="460">
                <StackPanel>
                    <!-- Icône + Titre -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="✅" FontSize="28"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel>
                            <TextBlock Text="MISE À JOUR DISPONIBLE"
                                       FontFamily="Consolas" FontSize="15"
                                       FontWeight="Bold" Foreground="#00CC66"/>
                            <TextBlock x:Name="OverlayVersionLabel"
                                       FontFamily="Consolas" FontSize="10"
                                       Foreground="#555" Margin="0,3,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <Separator Background="#1A2A3A" Margin="0,8,0,12"/>

                    <!-- Message explicatif -->
                    <TextBlock Text="Une mise à jour est requise pour continuer à utiliser l'application."
                               FontFamily="Consolas" FontSize="10"
                               Foreground="#888" TextWrapping="Wrap"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="La mise à jour a été téléchargée automatiquement."
                               FontFamily="Consolas" FontSize="10"
                               Foreground="#888" TextWrapping="Wrap"
                               Margin="0,0,0,14"/>

                    <!-- Notes de version -->
                    <TextBlock Text="NOUVEAUTÉS" FontFamily="Consolas"
                               FontSize="9" Foreground="#444" Margin="0,0,0,5"/>
                    <Border Background="#0A1A0A" CornerRadius="4" Padding="10,8" Margin="0,0,0,16">
                        <ScrollViewer MaxHeight="100" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="OverlayNotesLabel"
                                       FontFamily="Consolas" FontSize="10"
                                       Foreground="#AAA" TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Border>

                    <!-- Barre de progression téléchargement -->
                    <Border x:Name="OverlayProgressPanel"
                            Visibility="Collapsed"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock x:Name="OverlayProgressLabel"
                                       Text="Téléchargement en cours..."
                                       FontFamily="Consolas" FontSize="9"
                                       Foreground="#00CC66" Margin="0,0,0,4"/>
                            <ProgressBar x:Name="OverlayProgressBar"
                                         Height="6" Minimum="0" Maximum="100" Value="0"
                                         Background="#1A1A1A" Foreground="#00CC66"
                                         BorderThickness="0"/>
                            <TextBlock x:Name="OverlaySizeLabel"
                                       FontFamily="Consolas" FontSize="8"
                                       Foreground="#444" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Bouton Redémarrer -->
                    <Button x:Name="OverlayRestartBtn"
                            Content="🔄  Redémarrer et installer la mise à jour"
                            FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                            Foreground="White" Background="#00CC66"
                            BorderThickness="0" Height="44"
                            Cursor="Hand"
                            IsEnabled="False"
                            Click="OverlayRestartBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="5" Padding="20,0"
                                        Opacity="{TemplateBinding IsEnabled, Converter={x:Static local:BoolToOpacityConverter.Instance}}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#009944"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <TextBlock x:Name="OverlayWaitLabel"
                               Text="⏳ Téléchargement en cours — veuillez patienter..."
                               FontFamily="Consolas" FontSize="9"
                               Foreground="#555" HorizontalAlignment="Center"
                               Margin="0,8,0,0" Visibility="Visible"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══ OVERLAY LICENCE EXPIRÉE (bloquant) ══════════════════════════════
             Apparaît à l'heure EXACTE d'expiration, pendant que l'app tourne.
             Bloque toute interaction. L'utilisateur doit renouveler pour continuer.
        ════════════════════════════════════════════════════════════════════════ -->
        <Grid x:Name="LicenseExpiredOverlay"
              Visibility="Collapsed"
              Background="#CC000000"
              Panel.ZIndex="9998">

            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#0D1117"
                    BorderBrush="#FF3333"
                    BorderThickness="2"
                    CornerRadius="8"
                    Padding="36,28"
                    MinWidth="440">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="🔒" FontSize="26"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel>
                            <TextBlock Text="LICENCE EXPIRÉE"
                                       FontFamily="Consolas" FontSize="15"
                                       FontWeight="Bold" Foreground="#FF3333"/>
                            <TextBlock Text="Votre accès a expiré. L'application est bloquée."
                                       FontFamily="Consolas" FontSize="10"
                                       Foreground="#888" Margin="0,3,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <Separator Background="#1A2A3A" Margin="0,4,0,14"/>

                    <TextBlock FontFamily="Consolas" FontSize="10"
                               Foreground="#AAA" TextWrapping="Wrap" Margin="0,0,0,20"
                               Text="Pour continuer à utiliser l'application, entrez votre nouvelle clé de licence ci-dessous."/>

                    <Button x:Name="BtnRenewLicense"
                            Content="🔑  Entrer ma nouvelle clé de licence"
                            FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                            Foreground="White" Background="#FF3333"
                            BorderThickness="0" Height="44"
                            Cursor="Hand"
                            Click="BtnRenewLicense_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="5" Padding="20,0">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#CC0000"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

    </Grid> <!-- fin RootGrid -->
</Window>
