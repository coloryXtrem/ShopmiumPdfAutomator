<Window x:Class="ShopmiumPdfAutomator.SubmitToShopmiumWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📤 Envoyer à Shopmium"
        Width="620"
        SizeToContent="Height"
        MinHeight="300"
        WindowStartupLocation="CenterOwner"
        Background="#0B141C"
        Foreground="#C0D8F0"
        FontFamily="Consolas">

    <Window.Resources>
        <Style x:Key="DarkBtn" TargetType="Button">
            <Setter Property="Background" Value="#0A2840"/>
            <Setter Property="Foreground" Value="#00D4FF"/>
            <Setter Property="BorderBrush" Value="#1A4060"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#0F3858"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#0A1A2A"/>
                                <Setter Property="Foreground" Value="#405060"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource DarkBtn}">
            <Setter Property="Background" Value="#003D55"/>
            <Setter Property="Foreground" Value="#00D4FF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="20,10"/>
        </Style>
        <Style x:Key="SpinBtn" TargetType="Button" BasedOn="{StaticResource DarkBtn}">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="MinWidth" Value="28"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20,18,20,20">

            <!-- En-tête -->
            <TextBlock Text="📤  ENVOYER UNE DEMANDE DE REMBOURSEMENT"
                       FontSize="13" FontWeight="Bold"
                       Foreground="#00D4FF" Margin="0,0,0,6"/>
            <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="#58788A"
                       Margin="0,0,0,14">
                Envoi direct à Shopmium via l'API officielle.
            </TextBlock>

            <!-- Info offre -->
            <Border Background="#081018" BorderBrush="#1A3050" BorderThickness="1"
                    CornerRadius="5" Padding="12,9" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock x:Name="OfferTitleText" FontWeight="Bold" FontSize="12"
                               Foreground="#C0E8FF" TextWrapping="Wrap"/>
                    <TextBlock x:Name="OfferMetaText"  FontSize="9" Foreground="#506878"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Enseigne — affichage simple, synchronisé avec TYPE DE TICKET -->
            <TextBlock Text="ENSEIGNE" FontSize="9" Foreground="#506878"
                       Margin="0,0,0,4"/>
            <Border Background="#081018" BorderBrush="#1A3050" BorderThickness="1"
                    CornerRadius="4" Padding="10,7" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="ChainValueText"
                               Foreground="#00D4FF" FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text="  (synchronisé avec le TYPE DE TICKET)"
                               Foreground="#405868" FontSize="9"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Séparateur produits -->
            <TextBlock Text="🛒  PRODUITS À DÉCLARER" FontWeight="Bold"
                       Foreground="#00D4FF" FontSize="11" Margin="0,0,0,4"/>
            <TextBlock x:Name="ProductsHintText"
                       FontSize="9" Foreground="#506878" Margin="0,0,0,10"/>
            <ItemsControl x:Name="ProductsList" Margin="0,0,0,4"/>
            <TextBlock x:Name="TotalText"
                       FontSize="10" Foreground="#7A8898" Margin="0,6,0,14"/>

            <!-- Séparateur photos -->
            <TextBlock Text="📷  PHOTOS À FOURNIR" FontWeight="Bold"
                       Foreground="#00D4FF" FontSize="11" Margin="0,0,0,4"/>
            <TextBlock Text="Auto-détecté depuis l'API Shopmium."
                       FontSize="9" Foreground="#506878" Margin="0,0,0,10"/>
            <ItemsControl x:Name="ProofsList" Margin="0,0,0,4"/>

            <!-- Localisation -->
            <TextBlock Text="🌍  Localisation : Paris — Carrefour Siège (48.866, 2.348)"
                       FontSize="9" Foreground="#405868" Margin="0,14,0,16"/>

            <!-- Statut -->
            <TextBlock x:Name="StatusText"
                       Text="Sélectionnez les photos requises puis cliquez sur Envoyer."
                       TextWrapping="Wrap" FontSize="10"
                       Foreground="#7A8898" Margin="0,0,0,12"/>

            <!-- Boutons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Annuler" Style="{StaticResource DarkBtn}"
                        Width="90" Margin="0,0,10,0"
                        Click="BtnCancel_Click"/>
                <Button x:Name="BtnSubmit"
                        Content="📤  Envoyer à Shopmium"
                        Style="{StaticResource PrimaryBtn}" Width="210"
                        Click="BtnSubmit_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>
